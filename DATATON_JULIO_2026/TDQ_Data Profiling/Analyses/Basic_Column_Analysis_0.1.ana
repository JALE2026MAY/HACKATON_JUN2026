      <indicators xsi:type="dataquality.indicators:SoundexFreqIndicator" xmi:id="_YX0X02nTEfG21I2H12_xHA" count="41188" computed="true" distinctValueCount="4" uniqueValueCount="0" valueToFreq="" valueToDistinctFreq="">
