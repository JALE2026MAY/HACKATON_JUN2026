          <taggedValue xmi:id="_ZD4MgWnTEfG21I2H12_xHA" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_ZD4MgmnTEfG21I2H12_xHA" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_ZD4Mg2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_YXzxH2nTEfG21I2H12_xHA" count="41188" computed="true" distinctValueCount="3">
        <parameters xmi:id="_YXzxIGnTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmimnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Distinct_Count_0.1.definition#_ccHq0BF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZEHdEGnTEfG21I2H12_xHA" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_ZEHdEWnTEfG21I2H12_xHA" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_ZEHdEmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_ZEHdE2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DuplicateCountIndicator" xmi:id="_YXzxIWnTEfG21I2H12_xHA" count="41188" computed="true" duplicateValueCount="3">
        <parameters xmi:id="_YXzxImnTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmimnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Duplicate_Count_0.1.definition#_ccHq0hF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZEWtoGnTEfG21I2H12_xHA" name="Duplicate Count" label="Duplicate Count">
          <taggedValue xmi:id="_ZEWtoWnTEfG21I2H12_xHA" tag="Description" value="counts the number of duplicate rows. This number and the number of unique data equals the number of distinct rows"/>
          <taggedValue xmi:id="_ZEWtomnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of duplicated records"/>
          <sqlGenericExpression xmi:id="_ZEWto2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING COUNT(*) > 1) AS myquery" language="SQL"/>
          <sqlGenericExpression xmi:id="_ZEWtpGnTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) mycount FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING mycount > 1) AS myquery" language="MySQL"/>
