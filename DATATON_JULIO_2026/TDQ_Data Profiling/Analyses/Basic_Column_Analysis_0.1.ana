          <taggedValue xmi:id="_ZbfbQmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_ZbfbQ2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
