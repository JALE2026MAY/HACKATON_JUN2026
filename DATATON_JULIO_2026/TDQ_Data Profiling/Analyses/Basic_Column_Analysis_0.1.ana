        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Summary Statistics/Mean_0.1.definition#_ccI48RF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZTQsUGnTEfG21I2H12_xHA" name="Mean" label="Mean">
          <taggedValue xmi:id="_ZTQsUWnTEfG21I2H12_xHA" tag="Description" value="computes the mean (average) of the records"/>
          <taggedValue xmi:id="_ZTQsUmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the mean value of numerical records"/>
          <sqlGenericExpression xmi:id="_ZTQsU2nTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
          <sqlGenericExpression xmi:id="_ZTQsVGnTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="MySQL"/>
          <sqlGenericExpression xmi:id="_ZTQsVWnTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="Oracle"/>
          <sqlGenericExpression xmi:id="_ZTQsVmnTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="PostgreSQL"/>
          <sqlGenericExpression xmi:id="_ZTQsV2nTEfG21I2H12_xHA" body="SELECT SUM(CAST (&lt;%=__COLUMN_NAMES__%> AS REAL)), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="Teradata"/>
          <sqlGenericExpression xmi:id="_ZTQsWGnTEfG21I2H12_xHA" body="SELECT SUM(double(&lt;%=__COLUMN_NAMES__%>)), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="DB2"/>
        </builtInIndicatorDefinition>
      </indicators>
