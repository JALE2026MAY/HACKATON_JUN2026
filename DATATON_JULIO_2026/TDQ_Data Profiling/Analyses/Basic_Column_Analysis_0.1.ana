        <builtInIndicatorDefinition xmi:id="_Zn8i4GnTEfG21I2H12_xHA" name="Low Frequency Table" label="Low Frequency Table">
          <taggedValue xmi:id="_Zn8i4WnTEfG21I2H12_xHA" tag="Description" value="counts the number of records for each distinct record"/>
          <taggedValue xmi:id="_Zn8i4mnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the less frequent records"/>
          <sqlGenericExpression xmi:id="_Zn8i42nTEfG21I2H12_xHA" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> ORDER BY c ASC" language="SQL"/>
