        <builtInIndicatorDefinition xmi:id="_Y8DtQGnTEfG21I2H12_xHA" name="Null Count" label="Null Count">
          <taggedValue xmi:id="_Y8DtQWnTEfG21I2H12_xHA" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_Y8DtQmnTEfG21I2H12_xHA" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_Y8DtQ2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
