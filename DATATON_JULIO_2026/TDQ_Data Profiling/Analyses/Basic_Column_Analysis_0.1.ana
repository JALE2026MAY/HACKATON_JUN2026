      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_YX0YXmnTEfG21I2H12_xHA" count="41188" computed="true" distinctValueCount="26">
        <parameters xmi:id="_YX0YX2nTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmlGnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Distinct_Count_0.1.definition#_ccHq0BF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZZWtQGnTEfG21I2H12_xHA" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_ZZXUUGnTEfG21I2H12_xHA" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_ZZXUUWnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_ZZXUUmnTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>
