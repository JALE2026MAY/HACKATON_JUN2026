          <taggedValue xmi:id="_ZTt_UmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the less frequent records"/>
          <sqlGenericExpression xmi:id="_ZTt_U2nTEfG21I2H12_xHA" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> ORDER BY c ASC" language="SQL"/>
