        <builtInIndicatorDefinition xmi:id="_ZG7ggGnTEfG21I2H12_xHA" name="Soundex Frequency Table" label="Soundex Frequency Table">
          <taggedValue xmi:id="_ZG7ggWnTEfG21I2H12_xHA" tag="Description" value="counts the number of records for each record with a distinct soundex"/>
          <taggedValue xmi:id="_ZG7ggmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the most frequent records with respect to their soundex value"/>
          <sqlGenericExpression xmi:id="_ZG7gg2nTEfG21I2H12_xHA" body="SELECT MAX(&lt;%=__COLUMN_NAMES__%>), SOUNDEX(&lt;%=__COLUMN_NAMES__%>), COUNT(*) c, COUNT(DISTINCT &lt;%=__COLUMN_NAMES__%>) d FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY SOUNDEX(&lt;%=__COLUMN_NAMES__%>) ORDER BY d DESC,c DESC" language="SQL"/>
          <sqlGenericExpression xmi:id="_ZG7ghGnTEfG21I2H12_xHA" body="SELECT MAX(&lt;%=__COLUMN_NAMES__%>), SOUNDEX(&lt;%=__COLUMN_NAMES__%>) , COUNT(*) c, COUNT(DISTINCT &lt;%=__COLUMN_NAMES__%>) d FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY 2 ORDER BY d DESC,c DESC" language="MySQL"/>
