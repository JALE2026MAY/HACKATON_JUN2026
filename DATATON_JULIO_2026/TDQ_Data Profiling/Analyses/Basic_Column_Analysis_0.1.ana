      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_YX0Yc2nTEfG21I2H12_xHA" count="41188" computed="true" distinctValueCount="26">
        <parameters xmi:id="_YX0YdGnTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmlWnIEfG0Euo6tNno2w"/>
