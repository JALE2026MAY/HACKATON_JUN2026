      <indicators xsi:type="dataquality.indicators:SoundexFreqIndicator" xmi:id="_YXzxEmnTEfG21I2H12_xHA" count="41188" computed="true" distinctValueCount="3" uniqueValueCount="0" valueToFreq="" valueToDistinctFreq="">
        <parameters xmi:id="_YXzxE2nTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmiWnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Soundex/Soundex_Frequency_Table_0.1.definition#_VGep4Pa7Ed24-N3PsP_o-w"/>
        <builtInIndicatorDefinition xmi:id="_ZDGJYGnTEfG21I2H12_xHA" name="Soundex Frequency Table" label="Soundex Frequency Table">
          <taggedValue xmi:id="_ZDGJYWnTEfG21I2H12_xHA" tag="Description" value="counts the number of records for each record with a distinct soundex"/>
          <taggedValue xmi:id="_ZDGJYmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the most frequent records with respect to their soundex value"/>
          <sqlGenericExpression xmi:id="_ZDGJY2nTEfG21I2H12_xHA" body="SELECT MAX(&lt;%=__COLUMN_NAMES__%>), SOUNDEX(&lt;%=__COLUMN_NAMES__%>), COUNT(*) c, COUNT(DISTINCT &lt;%=__COLUMN_NAMES__%>) d FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY SOUNDEX(&lt;%=__COLUMN_NAMES__%>) ORDER BY d DESC,c DESC" language="SQL"/>
