        <builtInIndicatorDefinition xmi:id="_ZAPCoGnTEfG21I2H12_xHA" name="Pattern Frequency Table" label="Pattern Frequency Table">
          <taggedValue xmi:id="_ZAPCoWnTEfG21I2H12_xHA" tag="Description" value="counts the number of records for each distinct pattern"/>
