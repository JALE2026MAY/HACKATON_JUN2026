      <indicators xsi:type="dataquality.indicators:MeanIndicator" xmi:id="_YX0YJ2nTEfG21I2H12_xHA" count="41188" computed="true" sumStr="7124" datatype="4">
        <parameters xmi:id="_YX0YKGnTEfG21I2H12_xHA"/>
