          <taggedValue xmi:id="_Y8yGAWnTEfG21I2H12_xHA" tag="Description" value="counts the number of records for each distinct record"/>
          <taggedValue xmi:id="_Y8yGAmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the less frequent records"/>
          <sqlGenericExpression xmi:id="_Y8yGA2nTEfG21I2H12_xHA" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> ORDER BY c ASC" language="SQL"/>
