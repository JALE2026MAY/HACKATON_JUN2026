          <taggedValue xmi:id="_ZX0cMmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the mean value of numerical records"/>
          <sqlGenericExpression xmi:id="_ZX0cM2nTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
