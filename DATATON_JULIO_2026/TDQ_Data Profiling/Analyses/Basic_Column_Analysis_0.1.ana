      <indicators xsi:type="dataquality.indicators:RowCountIndicator" xmi:id="_YX0Xx2nTEfG21I2H12_xHA" count="41188" computed="true">
        <parameters xmi:id="_YX0XyGnTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmjWnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Row_Count_0.1.definition#_ccFOkBF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZJUGIGnTEfG21I2H12_xHA" name="Row Count" label="Row Count">
          <taggedValue xmi:id="_ZJUGIWnTEfG21I2H12_xHA" tag="Description" value="counts the number of rows"/>
          <taggedValue xmi:id="_ZJUGImnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_ZJUGI2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:NullCountIndicator" xmi:id="_YX0XyWnTEfG21I2H12_xHA" count="41188" computed="true">
        <parameters xmi:id="_YX0XymnTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmjWnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Null_Count_0.1.definition#_GrAeADh9Ed2XmO7pl5Yuyg"/>
        <builtInIndicatorDefinition xmi:id="_ZJgTYGnTEfG21I2H12_xHA" name="Null Count" label="Null Count">
          <taggedValue xmi:id="_ZJgTYWnTEfG21I2H12_xHA" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_ZJgTYmnTEfG21I2H12_xHA" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_ZJgTY2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_YX0Xy2nTEfG21I2H12_xHA" count="41188" computed="true" distinctValueCount="5">
        <parameters xmi:id="_YX0XzGnTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmjWnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Distinct_Count_0.1.definition#_ccHq0BF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZJsgoGnTEfG21I2H12_xHA" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_ZJsgoWnTEfG21I2H12_xHA" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_ZJsgomnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_ZJsgo2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:DuplicateCountIndicator" xmi:id="_YX0XzWnTEfG21I2H12_xHA" count="41188" computed="true" duplicateValueCount="5">
        <parameters xmi:id="_YX0XzmnTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmjWnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Duplicate_Count_0.1.definition#_ccHq0hF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZJ4t4GnTEfG21I2H12_xHA" name="Duplicate Count" label="Duplicate Count">
          <taggedValue xmi:id="_ZJ4t4WnTEfG21I2H12_xHA" tag="Description" value="counts the number of duplicate rows. This number and the number of unique data equals the number of distinct rows"/>
          <taggedValue xmi:id="_ZJ4t4mnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of duplicated records"/>
          <sqlGenericExpression xmi:id="_ZJ4t42nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING COUNT(*) > 1) AS myquery" language="SQL"/>
          <sqlGenericExpression xmi:id="_ZJ4t5GnTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) mycount FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING mycount > 1) AS myquery" language="MySQL"/>
          <sqlGenericExpression xmi:id="_ZJ4t5WnTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) mycount FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING COUNT(*) > 1) myquery" language="Oracle"/>
          <sqlGenericExpression xmi:id="_ZJ4t5mnTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) mycount FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING mycount > 1) AS myquery" language="Teradata"/>
          <sqlGenericExpression xmi:id="_ZJ4t52nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) mycount FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING COUNT(*) > 1) myquery" language="Microsoft SQL Server"/>
