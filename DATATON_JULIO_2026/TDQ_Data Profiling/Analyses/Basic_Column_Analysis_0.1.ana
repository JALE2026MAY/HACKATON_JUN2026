      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_YX0X4GnTEfG21I2H12_xHA" count="41188" computed="true" distinctValueCount="1544">
        <parameters xmi:id="_YX0X4WnTEfG21I2H12_xHA"/>
