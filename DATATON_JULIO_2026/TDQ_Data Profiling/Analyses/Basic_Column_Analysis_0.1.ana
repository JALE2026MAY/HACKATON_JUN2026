      <indicators xsi:type="dataquality.indicators:DuplicateCountIndicator" xmi:id="_YX0YNmnTEfG21I2H12_xHA" count="41188" computed="true" duplicateValueCount="3">
        <parameters xmi:id="_YX0YN2nTEfG21I2H12_xHA"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../metadata/fileDelimited/bank_additional_full_0.1.item#_htAmkmnIEfG0Euo6tNno2w"/>
        <indicatorDefinition href="../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Duplicate_Count_0.1.definition#_ccHq0hF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_ZU3O0GnTEfG21I2H12_xHA" name="Duplicate Count" label="Duplicate Count">
          <taggedValue xmi:id="_ZU3O0WnTEfG21I2H12_xHA" tag="Description" value="counts the number of duplicate rows. This number and the number of unique data equals the number of distinct rows"/>
          <taggedValue xmi:id="_ZU3O0mnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of duplicated records"/>
          <sqlGenericExpression xmi:id="_ZU3O02nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) FROM &lt;%=__TABLE_NAME__%>  m &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING COUNT(*) > 1) AS myquery" language="SQL"/>
