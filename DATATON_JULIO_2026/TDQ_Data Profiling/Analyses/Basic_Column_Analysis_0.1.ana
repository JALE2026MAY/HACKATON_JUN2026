          <taggedValue xmi:id="_Y7yAcmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_Y7yAc2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
      </indicators>
      <indicators xsi:type="dataquality.indicators:NullCountIndicator" xmi:id="_YXzwyWnTEfG21I2H12_xHA" count="41188" computed="true">
