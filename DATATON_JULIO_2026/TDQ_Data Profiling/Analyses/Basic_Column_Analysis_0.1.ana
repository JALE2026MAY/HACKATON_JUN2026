        <builtInIndicatorDefinition xmi:id="_ZMgkEGnTEfG21I2H12_xHA" name="Mean" label="Mean">
          <taggedValue xmi:id="_ZMgkEWnTEfG21I2H12_xHA" tag="Description" value="computes the mean (average) of the records"/>
          <taggedValue xmi:id="_ZMgkEmnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the mean value of numerical records"/>
          <sqlGenericExpression xmi:id="_ZMgkE2nTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
          <sqlGenericExpression xmi:id="_ZMgkFGnTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="MySQL"/>
          <sqlGenericExpression xmi:id="_ZMgkFWnTEfG21I2H12_xHA" body="SELECT SUM(&lt;%=__COLUMN_NAMES__%>), COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="Oracle"/>
