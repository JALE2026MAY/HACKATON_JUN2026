        <builtInIndicatorDefinition xmi:id="_ZcA_sGnTEfG21I2H12_xHA" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_ZcA_sWnTEfG21I2H12_xHA" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_ZcA_smnTEfG21I2H12_xHA" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_ZcA_s2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>
