          <taggedValue xmi:id="_ZF5lwmnTEfG21I2H12_xHA" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_ZF5lw2nTEfG21I2H12_xHA" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
