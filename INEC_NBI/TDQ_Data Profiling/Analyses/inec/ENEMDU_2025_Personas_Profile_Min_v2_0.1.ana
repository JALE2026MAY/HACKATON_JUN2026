          <taggedValue xmi:id="_usMTYmnAEfGQnbnMwrHD6w" tag="Purpose" value="evaluates the number of unique records"/>
          <sqlGenericExpression xmi:id="_usMTY2nAEfGQnbnMwrHD6w" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING COUNT(*) = 1) AS myquery" language="SQL"/>
