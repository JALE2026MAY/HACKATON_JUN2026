      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_s7-8DWnAEfGQnbnMwrHD6w" count="334786" computed="true">
        <parameters xmi:id="_s7-8DmnAEfGQnbnMwrHD6w"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../../metadata/fileDelimited/inec_fuentes_csv/personas_0.1.item#_4-R5aWmZEfGU0uNNhhorVA"/>
