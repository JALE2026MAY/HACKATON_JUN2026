      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_s7-UzGnAEfGQnbnMwrHD6w" count="334786" computed="true" blankCount="251628">
        <parameters xmi:id="_s7-UzWnAEfGQnbnMwrHD6w"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../../metadata/fileDelimited/inec_fuentes_csv/personas_0.1.item#_4-R5LWmZEfGU0uNNhhorVA"/>
