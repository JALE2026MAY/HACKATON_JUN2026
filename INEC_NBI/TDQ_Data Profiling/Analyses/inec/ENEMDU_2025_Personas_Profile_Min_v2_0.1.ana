      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_Uu8HuWnAEfGQnbnMwrHD6w" count="334786" computed="true" blankCount="50310">
        <parameters xmi:id="_Uu8HumnAEfGQnbnMwrHD6w"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../../metadata/fileDelimited/inec_fuentes_csv/personas_0.1.item#_4-R4_mmZEfGU0uNNhhorVA"/>
