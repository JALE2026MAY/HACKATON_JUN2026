          <taggedValue xmi:id="_tmf2oWnAEfGQnbnMwrHD6w" tag="Description" value="counts the number of unique rows (i.e. distinct rows with only one instance: rows that are not duplicated)"/>
          <taggedValue xmi:id="_tmf2omnAEfGQnbnMwrHD6w" tag="Purpose" value="evaluates the number of unique records"/>
          <sqlGenericExpression xmi:id="_tmf2o2nAEfGQnbnMwrHD6w" body="SELECT COUNT(*) FROM (SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> HAVING COUNT(*) = 1) AS myquery" language="SQL"/>
