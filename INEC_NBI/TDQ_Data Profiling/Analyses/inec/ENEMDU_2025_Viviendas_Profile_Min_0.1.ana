      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_ARkx22nIEfGQnbnMwrHD6w" count="104738" computed="true">
        <parameters xmi:id="_ARkx3GnIEfGQnbnMwrHD6w"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../../metadata/fileDelimited/inec_fuentes_csv/viviendas_0.1.item#_4VTYEGmaEfGU0uNNhhorVA"/>
