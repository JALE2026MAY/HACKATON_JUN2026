  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="160" posY="280">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_3" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String periodoContexto = context.periodo;&#xA;&#xA;int anioAnterior = java.time.LocalDate&#xA;.now(java.time.ZoneId.of(&quot;America/Guayaquil&quot;))&#xA;.minusYears(1)&#xA;.getYear();&#xA;&#xA;String periodo;&#xA;&#xA;//Si viene periodo desde contexto, usarlo&#xA;if (periodoContexto != null &amp;&amp; !periodoContexto.trim().equals(&quot;&quot;)) {&#xA; periodo = periodoContexto.trim();&#xA;} else {&#xA; // Si no viene periodo, usar año anterior&#xA; periodo = String.valueOf(anioAnterior);&#xA;}&#xA;&#xA;&#xA;String path_csv = context.inec_path + &quot;extract/&quot; + periodo + &quot;/BDDenemdu_vivienda_&quot; + periodo + &quot;_anual.csv&quot;;&#xA;&#xA;&#xA;String urlZip = &quot;https://www.ecuadorencifras.gob.ec/documentos/web-inec/EMPLEO/&quot; + periodo + &quot;/anual/2_BDD_DATOS_ABIERTOS_ENEMDU_&quot;+ periodo + &quot;_CSV.zip&quot;;&#xA;&#xA;String baseDir = context.inec_path;&#xA;String landingDir = baseDir + &quot;landing/&quot; + periodo;&#xA;String extractDir = baseDir + &quot;extract/&quot; + periodo;&#xA;String zipPath = landingDir + &quot;/ENEMDU_&quot; + periodo + &quot;.zip&quot;;&#xA;&#xA;// Crear carpetas&#xA;java.nio.file.Files.createDirectories(java.nio.file.Paths.get(landingDir));&#xA;java.nio.file.Files.createDirectories(java.nio.file.Paths.get(extractDir));&#xA;&#xA;// Descargar ZIP&#xA;System.out.println(&quot;Descargando ZIP desde:&quot;);&#xA;System.out.println(urlZip);&#xA;&#xA;try (&#xA;    java.io.InputStream in = new java.net.URL(urlZip).openStream()&#xA;) {&#xA;    java.nio.file.Files.copy(&#xA;        in,&#xA;        java.nio.file.Paths.get(zipPath),&#xA;        java.nio.file.StandardCopyOption.REPLACE_EXISTING&#xA;    );&#xA;}&#xA;&#xA;// Guardar rutas para los siguientes componentes&#xA;globalMap.put(&quot;PERIODO&quot;, periodo);&#xA;globalMap.put(&quot;ZIP_PATH&quot;, zipPath);&#xA;globalMap.put(&quot;EXTRACT_DIR&quot;, extractDir);&#xA;&#xA;System.out.println(&quot;ZIP descargado en:&quot;);&#xA;System.out.println(zipPath);&#xA;&#xA;System.out.println(&quot;Carpeta de extracción:&quot;);&#xA;System.out.println(extractDir);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="tJava_Descargar_Enemdu"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_3"/>
  </node>
