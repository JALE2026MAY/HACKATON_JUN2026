  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="160" posY="280">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_3" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String periodoContexto = context.url_nbi_censo;&#xA;&#xA;String periodo;&#xA;&#xA;//Si viene periodo desde contexto, usarlo&#xA;if (periodoContexto != null &amp;&amp; !periodoContexto.trim().equals(&quot;&quot;)) {&#xA; periodo = periodoContexto.trim();&#xA;} else {&#xA; // Si no viene periodo, usar año anterior&#xA; periodo = &quot;https://www.censoecuador.gob.ec/wp-content/uploads/2024/05/Tabulados_pobreza_por_NBI_CSV.zip&quot;;&#xA;}&#xA;&#xA;&#xA;String urlZip = periodo;&#xA;// String urlZip = &quot;https://www.ecuadorencifras.gob.ec/documentos/web-inec/EMPLEO/&quot; + periodo + &quot;/anual/2_BDD_DATOS_ABIERTOS_ENEMDU_&quot;+ periodo + &quot;_CSV.zip&quot;;&#xA;&#xA;String baseDir = context.inec_path;&#xA;java.nio.file.Path landingPath = java.nio.file.Paths.get(baseDir, &quot;landing&quot;, &quot;censo&quot;);&#xA;java.nio.file.Path extractPath = java.nio.file.Paths.get(baseDir, &quot;censo&quot;);&#xA;java.nio.file.Path zipFilePath = landingPath.resolve(&quot;Tabulados_pobreza_por_NBI_CSV.zip&quot;);&#xA;&#xA;// Crear carpetas&#xA;java.nio.file.Files.createDirectories(landingPath);&#xA;java.nio.file.Files.createDirectories(extractPath);&#xA;&#xA;// Descargar ZIP&#xA;System.out.println(&quot;Descargando ZIP desde:&quot;);&#xA;System.out.println(urlZip);&#xA;&#xA;&#xA;//Descargar con curl&#xA;ProcessBuilder pb = new ProcessBuilder(&#xA; &quot;curl&quot;,&#xA; &quot;-L&quot;,&#xA; &quot;--fail&quot;,&#xA; &quot;--silent&quot;,&#xA; &quot;--show-error&quot;,&#xA; &quot;-o&quot;,&#xA; zipFilePath.toString(),&#xA; urlZip&#xA;);&#xA;&#xA;pb.redirectErrorStream(true);&#xA;&#xA;Process p = pb.start();&#xA;&#xA;java.io.BufferedReader reader = new java.io.BufferedReader(&#xA; new java.io.InputStreamReader(p.getInputStream())&#xA;);&#xA;&#xA;String line;&#xA;while ((line = reader.readLine()) != null) {&#xA; System.out.println(line);&#xA;}&#xA;&#xA;int exitCode = p.waitFor();&#xA;&#xA;if (exitCode != 0) {&#xA; throw new RuntimeException(&quot;Error descargando ZIP con curl. Exit code: &quot; + exitCode);&#xA;}&#xA;&#xA;if (!java.nio.file.Files.exists(zipFilePath)) {&#xA; throw new RuntimeException(&quot;No se descargó el archivo ZIP: &quot; + zipFilePath.toString());&#xA;}&#xA;&#xA;// Guardar rutas para los siguientes componentes&#xA;globalMap.put(&quot;PERIODO&quot;, periodo);&#xA;globalMap.put(&quot;ZIP_PATH&quot;, zipFilePath.toString());&#xA;globalMap.put(&quot;EXTRACT_DIR&quot;, extractPath.toString());&#xA;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="descargar_nbi_censo"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_3"/>
