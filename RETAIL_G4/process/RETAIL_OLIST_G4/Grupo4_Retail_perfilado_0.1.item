    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT '&quot; + context.run_id + &quot;' AS run_id, &quot; &#xD;&#xA;+ &quot;DATE_SUB(UTC_TIMESTAMP(6), INTERVAL 5 HOUR) AS run_ts, &quot;&#xD;&#xA;+ &quot;'&quot; + context.current_table + &quot;' AS dataset, &quot;&#xD;&#xA;+ &quot;'&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;' AS column_name, &quot;&#xD;&#xA;+ &quot;'&quot; + ((String)globalMap.get(&quot;row2.data_type&quot;)) + &quot;' AS data_type, &quot;&#xD;&#xA;+ &quot;COUNT(*) AS rows_total, &quot;&#xD;&#xA;+ &quot;COALESCE(SUM(`&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;` IS NULL), 0) AS rows_null, &quot;&#xD;&#xA;+ &quot;COALESCE(ROUND(100.0 * SUM(`&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;` IS NULL) / NULLIF(COUNT(*), 0), 2), 0) AS pct_null, &quot;&#xD;&#xA;+ &quot;COUNT(DISTINCT `&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;`) AS cardinality, &quot;&#xD;&#xA;+ &quot;COALESCE(CAST(MIN(`&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;`) AS CHAR), 'N/A') AS min_val, &quot;&#xD;&#xA;+ &quot;COALESCE(CAST(MAX(`&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;`) AS CHAR), 'N/A') AS max_val, &quot;&#xD;&#xA;+ &quot;COALESCE(ROUND(AVG(CHAR_LENGTH(CAST(`&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;` AS CHAR))), 2), 0) AS avg_len, &quot;&#xD;&#xA;+ &quot;COALESCE((SELECT CAST(`&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;` AS CHAR) FROM &quot; + context.current_table + &quot; GROUP BY 1 ORDER BY COUNT(*) DESC LIMIT 1), 'N/A') AS pattern_top, &quot;&#xD;&#xA;+ &quot;COALESCE((SELECT ROUND(100.0 * MAX(cnt) / NULLIF((SELECT COUNT(*) FROM &quot; + context.current_table + &quot;), 0), 2) FROM (SELECT COUNT(*) AS cnt FROM &quot; + context.current_table + &quot; GROUP BY `&quot; + ((String)globalMap.get(&quot;row2.column_name&quot;)) + &quot;`) t), 0) AS pct_top &quot;&#xD;&#xA;+ &quot;FROM &quot; + context.current_table"/>
