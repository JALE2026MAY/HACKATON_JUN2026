  <node componentName="tMysqlInput" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="120" posY="280">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBInput_2" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DB_VERSION" value="MYSQL_8"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="false"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1" show="false"/>
    <elementParameter field="TEXT" name="HOST" value="context.ss_host"/>
    <elementParameter field="TEXT" name="PORT" value="context.ss_port"/>
    <elementParameter field="TEXT" name="DBNAME" value="context.ss_db"/>
    <elementParameter field="TEXT" name="TYPE" value="MySQL" show="false"/>
    <elementParameter field="TEXT" name="USER" value="context.ss_user"/>
    <elementParameter field="PASSWORD" name="PASS" value="context.ss_password"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT&#xD;&#xA;&#xD;&#xA;    load_run,&#xD;&#xA;&#xD;&#xA;    CONCAT_WS(' | ',&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN order_id IS NULL&#xD;&#xA;            THEN 'order_id nulo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN order_item_id IS NULL&#xD;&#xA;            THEN 'order_item_id nulo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN product_id IS NULL&#xD;&#xA;            THEN 'product_id nulo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN seller_id IS NULL&#xD;&#xA;            THEN 'seller_id nulo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN shipping_limit_date IS NULL&#xD;&#xA;            THEN 'shipping_limit_date nulo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN price IS NULL&#xD;&#xA;            THEN 'price nulo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN freight_value IS NULL&#xD;&#xA;            THEN 'freight_value nulo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN order_item_id IS NOT NULL&#xD;&#xA;             AND order_item_id NOT REGEXP '^[0-9]+$'&#xD;&#xA;            THEN 'order_item_id no numerico'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN price IS NOT NULL&#xD;&#xA;             AND price NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;            THEN 'price no numerico'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN freight_value IS NOT NULL&#xD;&#xA;             AND freight_value NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;            THEN 'freight_value no numerico'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN price REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;             AND CAST(price AS DECIMAL(10,2)) &lt;= 0&#xD;&#xA;            THEN 'price &lt;= 0'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN freight_value REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;             AND CAST(freight_value AS DECIMAL(10,2)) &lt; 0&#xD;&#xA;            THEN 'freight_value negativo'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN shipping_limit_date IS NOT NULL&#xD;&#xA;             AND STR_TO_DATE(&#xD;&#xA;                    shipping_limit_date,&#xD;&#xA;                    '%Y-%m-%d %H:%i:%s'&#xD;&#xA;                 ) IS NULL&#xD;&#xA;            THEN 'fecha invalida'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN NOT EXISTS (&#xD;&#xA;                SELECT 1&#xD;&#xA;                FROM raw.orders_g4 o&#xD;&#xA;                WHERE o.order_id = oi.order_id&#xD;&#xA;            )&#xD;&#xA;            THEN 'order_id inexistente'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN NOT EXISTS (&#xD;&#xA;                SELECT 1&#xD;&#xA;                FROM raw.product_g4 p&#xD;&#xA;                WHERE p.product_id = oi.product_id&#xD;&#xA;            )&#xD;&#xA;            THEN 'product_id inexistente'&#xD;&#xA;        END,&#xD;&#xA;&#xD;&#xA;        CASE&#xD;&#xA;            WHEN NOT EXISTS (&#xD;&#xA;                SELECT 1&#xD;&#xA;                FROM raw.sellers_g4 s&#xD;&#xA;                WHERE s.seller_id = oi.seller_id&#xD;&#xA;            )&#xD;&#xA;            THEN 'seller_id inexistente'&#xD;&#xA;        END&#xD;&#xA;&#xD;&#xA;    ) AS reject_reason,&#xD;&#xA;&#xD;&#xA;    CONCAT(&#xD;&#xA;        'order_id=',IFNULL(order_id,'NULL'),&#xD;&#xA;        '|item=',IFNULL(order_item_id,'NULL'),&#xD;&#xA;        '|product=',IFNULL(product_id,'NULL'),&#xD;&#xA;        '|seller=',IFNULL(seller_id,'NULL'),&#xD;&#xA;        '|price=',IFNULL(price,'NULL'),&#xD;&#xA;        '|freight=',IFNULL(freight_value,'NULL')&#xD;&#xA;    ) AS raw_payload&#xD;&#xA;&#xD;&#xA;FROM raw.order_items_g4 oi&#xD;&#xA;&#xD;&#xA;WHERE&#xD;&#xA;&#xD;&#xA;       order_id IS NULL&#xD;&#xA;    OR order_item_id IS NULL&#xD;&#xA;    OR product_id IS NULL&#xD;&#xA;    OR seller_id IS NULL&#xD;&#xA;    OR shipping_limit_date IS NULL&#xD;&#xA;    OR price IS NULL&#xD;&#xA;    OR freight_value IS NULL&#xD;&#xA;&#xD;&#xA;    OR order_item_id NOT REGEXP '^[0-9]+$'&#xD;&#xA;&#xD;&#xA;    OR price NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;    OR freight_value NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;&#xD;&#xA;    OR (&#xD;&#xA;        price REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;        AND CAST(price AS DECIMAL(10,2)) &lt;= 0&#xD;&#xA;    )&#xD;&#xA;&#xD;&#xA;    OR (&#xD;&#xA;        freight_value REGEXP '^[0-9]+(\\\\.[0-9]+)?$'&#xD;&#xA;        AND CAST(freight_value AS DECIMAL(10,2)) &lt; 0&#xD;&#xA;    )&#xD;&#xA;&#xD;&#xA;    OR STR_TO_DATE(&#xD;&#xA;        shipping_limit_date,&#xD;&#xA;        '%Y-%m-%d %H:%i:%s'&#xD;&#xA;       ) IS NULL&#xD;&#xA;&#xD;&#xA;    OR NOT EXISTS (&#xD;&#xA;        SELECT 1&#xD;&#xA;        FROM raw.orders_g4 o&#xD;&#xA;        WHERE o.order_id = oi.order_id&#xD;&#xA;    )&#xD;&#xA;&#xD;&#xA;    OR NOT EXISTS (&#xD;&#xA;        SELECT 1&#xD;&#xA;        FROM raw.product_g4 p&#xD;&#xA;        WHERE p.product_id = oi.product_id&#xD;&#xA;    )&#xD;&#xA;&#xD;&#xA;    OR NOT EXISTS (&#xD;&#xA;        SELECT 1&#xD;&#xA;        FROM raw.sellers_g4 s&#xD;&#xA;        WHERE s.seller_id = oi.seller_id&#xD;&#xA;    );&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" value="mysql_id" show="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;noDatetimeStringSync=true&quot;"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
    <elementParameter field="TECHNICAL" name="ENCODING:ENCODING_TYPE" value="ISO-8859-15"/>
    <elementParameter field="CHECK" name="ENABLE_STREAM" value="false"/>
    <elementParameter field="CHECK" name="TRIM_ALL_COLUMN" value="false"/>
    <elementParameter field="TABLE" name="TRIM_COLUMN">
      <elementValue elementRef="SCHEMA_COLUMN" value="load_run" id="0"/>
      <elementValue elementRef="TRIM" value="false" id="1"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="reject_reason" id="2"/>
      <elementValue elementRef="TRIM" value="false" id="3"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="raw_payload" id="4"/>
      <elementValue elementRef="TRIM" value="false" id="5"/>
    </elementParameter>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tDBInput_2">
      <column comment="" key="false" length="-1" name="load_run" nullable="true" pattern="" precision="-1" sourceType="VARCHAR" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="reject_reason" nullable="true" pattern="" precision="-1" sourceType="LONGTEXT" type="id_String" originalLength="-1" usefulColumn="true"/>
      <column comment="" key="false" length="-1" name="raw_payload" nullable="true" pattern="" precision="-1" sourceType="LONGTEXT" type="id_String" originalLength="-1" usefulColumn="true"/>
    </metadata>
