    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT load_run, load_ts, CONCAT(IF(order_id IS NULL OR TRIM(order_id)='','DQ-001 order_id nulo/vacio | ',''),IF(payment_sequential IS NULL,'DQ-002 payment_sequential nulo | ',''),IF(payment_type IS NULL OR TRIM(payment_type)='','DQ-003 payment_type nulo/vacio | ',''),IF(payment_installments IS NULL,'DQ-004 payment_installments nulo | ',''),IF(payment_value IS NULL,'DQ-005 payment_value nulo | ',''),IF(payment_type IS NOT NULL AND LOWER(TRIM(payment_type)) NOT IN ('credit_card','boleto','voucher','debit_card','not_defined'),'DQ-006 payment_type invalido | ',''),IF(payment_sequential IS NOT NULL AND payment_sequential &lt;= 0,'DQ-007 payment_sequential menor o igual a 0 | ',''),IF(payment_installments IS NOT NULL AND payment_installments &lt; 0,'DQ-008 payment_installments negativo | ',''),IF(payment_value IS NOT NULL AND payment_value &lt;= 0,'DQ-009 payment_value menor o igual a 0 | ','')) AS reject_reason, CONCAT('{','\&quot;order_id\&quot;:\&quot;',IFNULL(order_id,''),'\&quot;,','\&quot;payment_sequential\&quot;:\&quot;',IFNULL(CAST(payment_sequential AS CHAR),''),'\&quot;,','\&quot;payment_type\&quot;:\&quot;',IFNULL(payment_type,''),'\&quot;,','\&quot;payment_installments\&quot;:\&quot;',IFNULL(CAST(payment_installments AS CHAR),''),'\&quot;,','\&quot;payment_value\&quot;:\&quot;',IFNULL(CAST(payment_value AS CHAR),''),'\&quot;','}') AS raw_payload FROM raw.order_payments_g4 WHERE order_id IS NULL OR TRIM(order_id)='' OR payment_sequential IS NULL OR payment_type IS NULL OR TRIM(payment_type)='' OR payment_installments IS NULL OR payment_value IS NULL OR LOWER(TRIM(payment_type)) NOT IN ('credit_card','boleto','voucher','debit_card','not_defined') OR payment_sequential &lt;= 0 OR payment_installments &lt; 0 OR payment_value &lt;= 0;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
