      <elementValue elementRef="TRIM" value="false" id="11"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="order_delivered_customer_date" id="12"/>
      <elementValue elementRef="TRIM" value="false" id="13"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="order_estimated_delivery_date" id="14"/>
      <elementValue elementRef="TRIM" value="false" id="15"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="load_ts" id="16"/>
      <elementValue elementRef="TRIM" value="false" id="17"/>
      <elementValue elementRef="SCHEMA_COLUMN" value="load_run" id="18"/>
      <elementValue elementRef="TRIM" value="false" id="19"/>
    </elementParameter>
