    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"/>
      <varTables sizeState="INTERMEDIATE" name="Var" minimized="true"/>
      <outputTables sizeState="INTERMEDIATE" name="out_orders">
        <mapperTableEntries name="order_id" expression="row1.order_id " type="id_String" nullable="true"/>
        <mapperTableEntries name="customer_id" expression="row1.customer_id " type="id_String" nullable="true"/>
        <mapperTableEntries name="order_status" expression="row1.order_status " type="id_String" nullable="true"/>
        <mapperTableEntries name="order_purchase_timestamp" expression="row1.order_purchase_timestamp == null || row1.order_purchase_timestamp.trim().isEmpty()&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;? null&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;: TalendDate.parseDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, row1.order_purchase_timestamp) " type="id_Date" nullable="true"/>
        <mapperTableEntries name="order_approved_at" expression="row1.order_approved_at == null || row1.order_approved_at.trim().isEmpty()&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;? null&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;: TalendDate.parseDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, row1.order_approved_at) " type="id_Date" nullable="true"/>
