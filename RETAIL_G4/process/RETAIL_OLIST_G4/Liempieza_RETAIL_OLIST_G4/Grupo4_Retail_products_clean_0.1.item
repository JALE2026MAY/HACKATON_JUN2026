    <elementParameter field="TEXT" name="USER" value="context.ss_user"/>
    <elementParameter field="PASSWORD" name="PASS" value="context.ss_password"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;product_g4&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT load_run, load_ts, CONCAT(IF(product_id IS NULL,'product_id nulo | ',''), IF(product_category_name IS NULL,'product_category_name nulo | ',''), IF(product_name_lenght IS NULL,'product_name_lenght nulo | ',''), IF(product_description_lenght IS NULL,'product_description_lenght nulo | ',''), IF(product_photos_qty IS NULL,'product_photos_qty nulo | ',''), IF(product_weight_g IS NULL,'product_weight_g nulo | ',''), IF(product_length_cm IS NULL,'product_length_cm nulo | ',''), IF(product_height_cm IS NULL,'product_height_cm nulo | ',''), IF(product_width_cm IS NULL,'product_width_cm nulo | ',''), IF(product_name_lenght IS NOT NULL AND TRIM(product_name_lenght) NOT REGEXP '^[0-9]+$','product_name_lenght no numerico | ',''), IF(product_description_lenght IS NOT NULL AND TRIM(product_description_lenght) NOT REGEXP '^[0-9]+$','product_description_lenght no numerico | ',''), IF(product_photos_qty IS NOT NULL AND TRIM(product_photos_qty) NOT REGEXP '^[0-9]+$','product_photos_qty no numerico | ',''), IF(product_weight_g IS NOT NULL AND TRIM(product_weight_g) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$','product_weight_g no numerico | ',''), IF(product_length_cm IS NOT NULL AND TRIM(product_length_cm) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$','product_length_cm no numerico | ',''), IF(product_height_cm IS NOT NULL AND TRIM(product_height_cm) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$','product_height_cm no numerico | ',''), IF(product_width_cm IS NOT NULL AND TRIM(product_width_cm) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$','product_width_cm no numerico | ',''), IF(product_id IN (SELECT product_id FROM raw.product_g4 GROUP BY product_id HAVING COUNT(*) > 1),'product_id duplicado | ','')) AS reject_reason, CONCAT('{','product_id:',IFNULL(product_id,''),', product_category_name:',IFNULL(product_category_name,''),', product_name_lenght:',IFNULL(product_name_lenght,''),', product_description_lenght:',IFNULL(product_description_lenght,''),', product_photos_qty:',IFNULL(product_photos_qty,''),', product_weight_g:',IFNULL(product_weight_g,''),', product_length_cm:',IFNULL(product_length_cm,''),', product_height_cm:',IFNULL(product_height_cm,''),', product_width_cm:',IFNULL(product_width_cm,''),'}') AS raw_payload FROM raw.product_g4 WHERE product_id IS NULL OR product_category_name IS NULL OR product_name_lenght IS NULL OR product_description_lenght IS NULL OR product_photos_qty IS NULL OR product_weight_g IS NULL OR product_length_cm IS NULL OR product_height_cm IS NULL OR product_width_cm IS NULL OR TRIM(product_name_lenght) NOT REGEXP '^[0-9]+$' OR TRIM(product_description_lenght) NOT REGEXP '^[0-9]+$' OR TRIM(product_photos_qty) NOT REGEXP '^[0-9]+$' OR TRIM(product_weight_g) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$' OR TRIM(product_length_cm) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$' OR TRIM(product_height_cm) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$' OR TRIM(product_width_cm) NOT REGEXP '^[0-9]+(\\\\.[0-9]+)?$' OR product_id IN (SELECT product_id FROM raw.product_g4 GROUP BY product_id HAVING COUNT(*) > 1)&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
