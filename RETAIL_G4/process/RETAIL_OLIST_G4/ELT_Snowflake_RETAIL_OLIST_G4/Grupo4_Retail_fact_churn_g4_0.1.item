  <node componentName="SnowflakeInput" componentVersion="1" offsetLabelX="0" offsetLabelY="0" posX="320" posY="280">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBInput_1" show="false"/>
    <elementParameter field="TECHNICAL" name="TACOKIT_COMPONENT_ID" value="c25vd2ZsYWtlI1Nub3dmbGFrZSNJbnB1dA" show="false"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="CLOSED_LIST" name="configuration.dataSet.dataStore.snowflakeAuth.authenticationType" value="BASIC" show="false"/>
    <elementParameter field="CLOSED_LIST" name="configuration.dataSet.dataStore.snowflakeAuth.grantType" value="CLIENT_CREDENTIALS" show="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.shareConnection" value="false" show="false"/>
    <elementParameter field="TACOKIT_VALUE_SELECTION" name="configuration.dataSet.tableName" value="FACT_ORDERS"/>
    <elementParameter field="CHECK" name="configuration.dataSet.manualQuery" value="true"/>
    <elementParameter field="MEMO_SQL" name="configuration.dataSet.sqlQuery" value="&quot;WITH rfm AS (&#xD;&#xA;    SELECT&#xD;&#xA;        o.CUSTOMER_KEY,&#xD;&#xA;&#xD;&#xA;        DATEDIFF(&#xD;&#xA;            'day',&#xD;&#xA;            MAX(dt.DATE),&#xD;&#xA;            '2018-10-29'&#xD;&#xA;        ) AS recency_days,&#xD;&#xA;&#xD;&#xA;        COUNT(*) AS frequency_count,&#xD;&#xA;        SUM(o.total_amount) AS monetary_value&#xD;&#xA;&#xD;&#xA;    FROM FACT.FACT_ORDERS o&#xD;&#xA;    INNER JOIN DIM.DIM_DATE dt&#xD;&#xA;        ON o.order_purchase_timestamp = dt.DATA_KEY&#xD;&#xA;&#xD;&#xA;    GROUP BY o.CUSTOMER_KEY&#xD;&#xA;),&#xD;&#xA;&#xD;&#xA;rfm_norm AS (&#xD;&#xA;    SELECT&#xD;&#xA;        CUSTOMER_KEY,&#xD;&#xA;&#xD;&#xA;        recency_days,&#xD;&#xA;        frequency_count,&#xD;&#xA;        monetary_value,&#xD;&#xA;&#xD;&#xA;        -- Normalización básica (min-max simplificado)&#xD;&#xA;        (recency_days - MIN(recency_days) OVER()) &#xD;&#xA;            / NULLIF(MAX(recency_days) OVER() - MIN(recency_days) OVER(), 0) AS recency_norm,&#xD;&#xA;&#xD;&#xA;        (frequency_count - MIN(frequency_count) OVER())&#xD;&#xA;            / NULLIF(MAX(frequency_count) OVER() - MIN(frequency_count) OVER(), 0) AS frequency_norm,&#xD;&#xA;&#xD;&#xA;        (monetary_value - MIN(monetary_value) OVER())&#xD;&#xA;            / NULLIF(MAX(monetary_value) OVER() - MIN(monetary_value) OVER(), 0) AS monetary_norm&#xD;&#xA;&#xD;&#xA;    FROM rfm&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;SELECT&#xD;&#xA;    CUSTOMER_KEY,&#xD;&#xA;    recency_days,&#xD;&#xA;    frequency_count,&#xD;&#xA;    monetary_value,&#xD;&#xA;&#xD;&#xA;    -- Inversión de recency (más recency = peor)&#xD;&#xA;    (1 - recency_norm) * 0.5&#xD;&#xA;    + frequency_norm * 0.3&#xD;&#xA;    + monetary_norm * 0.2 AS churn_risk_score&#xD;&#xA;&#xD;&#xA;FROM rfm_norm;&quot;"/>
    <elementParameter field="CHECK" name="configuration.dataSet.dataStore.autoCommit" value="true" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.loginTimeout" value="15" show="false"/>
    <elementParameter field="TEXT" name="configuration.dataSet.dataStore.jdbcUrlSuffix" value=".snowflakecomputing.com" show="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.useUnquotedObjectIdentifiers" value="true" show="false"/>
    <elementParameter field="CHECK" name="configuration.dataSet.useSessionTimezone" value="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1"/>
    <elementParameter field="TECHNICAL" name="configuration.dataSet.__version" value="-1" show="false"/>
    <elementParameter field="TECHNICAL" name="configuration.dataSet.dataStore.__version" value="-1" show="false"/>
    <metadata connector="FLOW" name="tDBInput_1">
      <column comment="" defaultValue="" key="false" length="38" name="CUSTOMER_KEY" nullable="true" pattern="" precision="0" sourceType="NUMBER" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" defaultValue="" key="false" length="9" name="RECENCY_DAYS" nullable="true" pattern="" precision="0" sourceType="NUMBER" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" defaultValue="" key="false" length="18" name="FREQUENCY_COUNT" nullable="false" pattern="" precision="0" sourceType="NUMBER" type="id_Integer" originalLength="-1" usefulColumn="true"/>
      <column comment="" defaultValue="" key="false" length="-1" name="MONETARY_VALUE" nullable="true" pattern="" precision="-1" sourceType="DOUBLE" type="id_Double" originalLength="-1" usefulColumn="true"/>
      <column comment="" defaultValue="" key="false" length="-1" name="CHURN_RISK_SCORE" nullable="true" pattern="" precision="-1" sourceType="DOUBLE" type="id_Double" originalLength="-1" usefulColumn="true"/>
    </metadata>
    <metadata connector="LOOKUP" name="LOOKUP"/>
    <metadata connector="MERGE" name="MERGE"/>
    <metadata connector="REJECT" name="REJECT"/>
