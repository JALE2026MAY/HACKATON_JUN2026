    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &#xD;&#xA;    o.customer_id, &#xD;&#xA;    ot.product_id,&#xD;&#xA;    ot.seller_id,&#xD;&#xA;    DATE_FORMAT(o.order_purchase_timestamp, '%Y%m%d') AS order_purchase_timestamp, &#xD;&#xA;    DATE_FORMAT(o.order_estimated_delivery_date, '%Y%m%d') AS estimated_delivery_date, &#xD;&#xA;    DATE_FORMAT(o.order_delivered_customer_date, '%Y%m%d') AS delivered_customer_date, &#xD;&#xA;    ot.price,&#xD;&#xA;    ot.freight_value,&#xD;&#xA;    (ot.price + ot.freight_value) AS total_amount&#xD;&#xA;FROM stg.order_items_g4 AS ot&#xD;&#xA;INNER JOIN stg.orders_g4 AS o ON ot.order_id = o.order_id;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
