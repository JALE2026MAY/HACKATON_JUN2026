    <taggedValue xmi:id="_KR9qk2qHEfG5aM4fdR_Gwg" tag="Purpose" value="Validar la completitud, unicidad y trazabilidad técnica de los registros de clientes en la capa STG/Silver del producto TELCO Retention Intelligence."/>
    <taggedValue xmi:id="_KR9qlGqHEfG5aM4fdR_Gwg" tag="Description" value="Este análisis perfila las columnas de identificación y trazabilidad de la tabla stg_telco_customer_churn_grupo_uno. El objetivo es comprobar que customer_id esté completo, sea único y no presente duplicados, además de validar que los campos técnicos source_run_id, stg_run_id, source_file, source_row_number, processed_at y stg_quality_status permitan rastrear cada registro desde la carga RAW/Bronze hasta la capa STG/Silver."/>
    <taggedValue xmi:id="_KR9qlWqHEfG5aM4fdR_Gwg" tag="Version" value="0.1"/>
    <taggedValue xmi:id="_Zvc20WqIEfG5aM4fdR_Gwg" tag="ANA_LAST_RUN_CONTEXT" value="Default"/>
