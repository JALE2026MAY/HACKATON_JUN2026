      <indicators xsi:type="dataquality.indicators:UniqueCountIndicator" xmi:id="_WwVoE2qNEfG1lqxu6qhfiQ" count="7043" computed="true" uniqueValueCount="7043">
        <parameters xmi:id="_WwVoFGqNEfG1lqxu6qhfiQ"/>
        <analyzedElement xsi:type="relational:TdColumn" href="../../../metadata/connections/CONN_SINGLESTORE_TELCO_G1_0.1.item#_ZmfnwGqLEfG5aM4fdR_Gwg"/>
