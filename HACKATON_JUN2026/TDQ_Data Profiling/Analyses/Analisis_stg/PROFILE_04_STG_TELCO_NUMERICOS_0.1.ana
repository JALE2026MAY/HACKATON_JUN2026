  <dataquality.analysis:Analysis xmi:id="_1bJ6IWqOEfG1lqxu6qhfiQ" name="PROFILE_04_STG_TELCO_NUMERICOS" supplierDependency="_NPHMoGqREfG1lqxu6qhfiQ" creationDate="2026-06-17T15:55:12.834-0500" defaultContext="Default">
    <clientDependency href="../../../metadata/connections/CONN_SINGLESTORE_TELCO_G1_0.1.item#_2A-EUGqLEfG5aM4fdR_Gwg"/>
    <taggedValue xmi:id="_1bJ6ImqOEfG1lqxu6qhfiQ" tag="Status" value="Draft"/>
    <taggedValue xmi:id="_1bJ6I2qOEfG1lqxu6qhfiQ" tag="Author" value="jeferson.monje@trial.f221wfxsdlu6mpk.us.qlikcloud.com"/>
    <taggedValue xmi:id="_1bJ6JGqOEfG1lqxu6qhfiQ" tag="Purpose" value="Perfilar las variables numéricas y flags binarios de la capa STG/Silver para validar rangos, valores mínimos, máximos, promedios, nulos y distribución de indicadores derivados."/>
    <taggedValue xmi:id="_1bJ6JWqOEfG1lqxu6qhfiQ" tag="Description" value="Este análisis revisa las columnas senior_citizen, partner_flag, dependents_flag, tenure_months, paperless_billing_flag, monthly_charges, total_charges, total_charges_was_imputed, churn_flag y service_score de la tabla stg_telco_customer_churn_grupo_uno. El objetivo es comprobar que las conversiones numéricas realizadas en STG/Silver fueron correctas, que no existen rangos incoherentes y que los flags binarios contienen únicamente valores válidos 0 y 1. También se revisa service_score como variable derivada para segmentación posterior."/>
    <taggedValue xmi:id="_1bJ6JmqOEfG1lqxu6qhfiQ" tag="Version" value="0.1"/>
    <taggedValue xmi:id="_JfWBMGqPEfG1lqxu6qhfiQ" tag="PREVIEW_ROW_NUMBER" value="50"/>
