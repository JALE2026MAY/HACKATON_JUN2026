  <dataquality.analysis:Analysis xmi:id="_PZeA0GqQEfG1lqxu6qhfiQ" name="PROFILE_05_STG_TELCO_SEGMENTACIONES" supplierDependency="_NPPvgGqREfG1lqxu6qhfiQ" creationDate="2026-06-17T16:05:16.636-0500" defaultContext="Default">
    <clientDependency href="../../../metadata/connections/CONN_SINGLESTORE_TELCO_G1_0.1.item#_2A-EUGqLEfG5aM4fdR_Gwg"/>
    <taggedValue xmi:id="_PZeA0WqQEfG1lqxu6qhfiQ" tag="Status" value="Draft"/>
    <taggedValue xmi:id="_PZeA0mqQEfG1lqxu6qhfiQ" tag="Author" value="jeferson.monje@trial.f221wfxsdlu6mpk.us.qlikcloud.com"/>
    <taggedValue xmi:id="_PZeA02qQEfG1lqxu6qhfiQ" tag="Purpose" value="Perfilar las columnas derivadas de segmentación creadas en STG/Silver para validar su completitud, distribución y utilidad analítica para la capa GOLD y el dashboard ejecutivo."/>
    <taggedValue xmi:id="_PZeA1GqQEfG1lqxu6qhfiQ" tag="Description" value="Este análisis revisa las columnas service_level, tenure_segment, monthly_charge_band, segment_key, stg_quality_status y stg_notes de la tabla stg_telco_customer_churn_grupo_uno. El objetivo es validar que las segmentaciones derivadas durante la transformación STG/Silver se hayan generado de forma completa y consistente, permitiendo clasificar clientes por nivel de servicios, antigüedad, nivel de cargo mensual y combinaciones analíticas relevantes para churn y retención."/>
    <taggedValue xmi:id="_PZeA1WqQEfG1lqxu6qhfiQ" tag="Version" value="0.1"/>
    <taggedValue xmi:id="_cYKr4GqQEfG1lqxu6qhfiQ" tag="PREVIEW_ROW_NUMBER" value="50"/>
