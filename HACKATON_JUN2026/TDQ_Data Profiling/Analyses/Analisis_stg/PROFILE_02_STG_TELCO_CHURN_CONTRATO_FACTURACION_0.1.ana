        <instantiatedExpressions xsi:type="relational:TdExpression" xmi:id="_MpZ-62qOEfG1lqxu6qhfiQ" body="SELECT COUNT(`contract_type`) FROM `DSADEV`.`stg_telco_customer_churn_grupo_uno` WHERE TRIM(`contract_type`) = '' " language="MySQL"/>
        <builtInIndicatorDefinition xmi:id="_Mm1MAGqOEfG1lqxu6qhfiQ" name="Blank Count" label="Blank Count">
          <taggedValue xmi:id="_Mm1MAWqOEfG1lqxu6qhfiQ" tag="Description" value="counts the number of blank rows. A blank is a non null textual data that contains only white spaces (or nothing). Note that Oracle does not distinguish between the empty string and the null value"/>
          <taggedValue xmi:id="_Mm1MAmqOEfG1lqxu6qhfiQ" tag="Purpose" value="evaluates the number of blank records"/>
          <sqlGenericExpression xmi:id="_Mm1MA2qOEfG1lqxu6qhfiQ" body="SELECT COUNT(&lt;%=__COLUMN_NAMES__%>) FROM &lt;%=__TABLE_NAME__%> WHERE TRIM(&lt;%=__COLUMN_NAMES__%>) = '' &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
