  <dataquality.analysis:Analysis xmi:id="_uUJQoGqNEfG1lqxu6qhfiQ" name="PROFILE_02_STG_TELCO_CHURN_CONTRATO_FACTURACION" supplierDependency="_NO5KMGqREfG1lqxu6qhfiQ" creationDate="2026-06-17T15:47:15.616-0500" defaultContext="Default">
