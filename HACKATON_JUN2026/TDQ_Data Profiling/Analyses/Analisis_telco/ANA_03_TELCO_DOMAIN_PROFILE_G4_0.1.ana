      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_4BPGk2ncEfGJXK0qJt55Ng" count="7043" computed="true">
        <parameters xmi:id="_4BPGlGncEfGJXK0qJt55Ng"/>
