          <taggedValue xmi:id="_4QJFImncEfGJXK0qJt55Ng" tag="Purpose" value="evaluates the number of records"/>
          <sqlGenericExpression xmi:id="_4QJFI2ncEfGJXK0qJt55Ng" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>" language="SQL"/>
        </builtInIndicatorDefinition>
