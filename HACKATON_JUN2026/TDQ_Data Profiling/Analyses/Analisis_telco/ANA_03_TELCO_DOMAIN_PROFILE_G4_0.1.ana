        <indicatorDefinition href="../../../TDQ_Libraries/Indicators/System Indicators/Simple Statistics/Null_Count_0.1.definition#_GrAeADh9Ed2XmO7pl5Yuyg"/>
        <builtInIndicatorDefinition xmi:id="_4QOksGncEfGJXK0qJt55Ng" name="Null Count" label="Null Count">
          <taggedValue xmi:id="_4QOksWncEfGJXK0qJt55Ng" tag="Purpose" value="evaluate the number of missing data (null records)"/>
          <taggedValue xmi:id="_4QOksmncEfGJXK0qJt55Ng" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_4QOks2ncEfGJXK0qJt55Ng" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
