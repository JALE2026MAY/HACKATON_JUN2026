      <indicators xsi:type="dataquality.indicators:MinLengthIndicator" xmi:id="_4BOgJGncEfGJXK0qJt55Ng" count="7043" computed="true" length="2">
        <parameters xmi:id="_4BOgJWncEfGJXK0qJt55Ng">
          <textParameter xmi:id="_4BOgJmncEfGJXK0qJt55Ng" useBlank="false"/>
        </parameters>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../../metadata/fileDelimited/Telcom_0.1.item#_cHMsP2nWEfGJXK0qJt55Ng"/>
        <indicatorDefinition href="../../../TDQ_Libraries/Indicators/System Indicators/Text Statistics/Minimal_Length_0.1.definition#_ccHq1BF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_4YrWEGncEfGJXK0qJt55Ng" name="Minimal Length" label="Minimal Length">
