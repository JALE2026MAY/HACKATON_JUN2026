      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_4BN4gWncEfGJXK0qJt55Ng" count="7043" computed="true">
        <parameters xmi:id="_4BN4gmncEfGJXK0qJt55Ng"/>
