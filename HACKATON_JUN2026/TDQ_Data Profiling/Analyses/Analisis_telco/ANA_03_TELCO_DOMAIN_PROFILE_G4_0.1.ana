      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_4BOfzWncEfGJXK0qJt55Ng" count="7043" computed="true" distinctValueCount="3">
        <parameters xmi:id="_4BOfzmncEfGJXK0qJt55Ng"/>
