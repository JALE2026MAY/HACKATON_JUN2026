      <indicators xsi:type="dataquality.indicators:MinLengthIndicator" xmi:id="_4BOf8mncEfGJXK0qJt55Ng" count="7043" computed="true" length="2">
        <parameters xmi:id="_4BOf82ncEfGJXK0qJt55Ng">
