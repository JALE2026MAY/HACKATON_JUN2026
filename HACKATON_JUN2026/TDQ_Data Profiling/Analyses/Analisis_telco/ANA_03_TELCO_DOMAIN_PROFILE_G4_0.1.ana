          <taggedValue xmi:id="_4NG_QmncEfGJXK0qJt55Ng" tag="Purpose" value="evaluates the less frequent records"/>
          <sqlGenericExpression xmi:id="_4NG_Q2ncEfGJXK0qJt55Ng" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> ORDER BY c ASC" language="SQL"/>
