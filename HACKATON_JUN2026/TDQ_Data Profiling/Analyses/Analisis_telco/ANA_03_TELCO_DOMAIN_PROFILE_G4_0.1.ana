      <indicators xsi:type="dataquality.indicators:FrequencyIndicator" xmi:id="_4BN4c2ncEfGJXK0qJt55Ng" count="7043" computed="true" distinctValueCount="2" uniqueValueCount="0" valueToFreq="">
