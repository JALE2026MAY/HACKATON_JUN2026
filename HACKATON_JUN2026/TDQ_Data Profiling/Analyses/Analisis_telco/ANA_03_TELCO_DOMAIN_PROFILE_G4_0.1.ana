          <taggedValue xmi:id="_4ay18mncEfGJXK0qJt55Ng" tag="Purpose" value="evaluates the most frequent records"/>
          <sqlGenericExpression xmi:id="_4ay182ncEfGJXK0qJt55Ng" body="SELECT &lt;%=__COLUMN_NAMES__%>, COUNT(*) c FROM &lt;%=__TABLE_NAME__%> t &lt;%=__WHERE_CLAUSE__%> GROUP BY &lt;%=__COLUMN_NAMES__%> ORDER BY c DESC" language="SQL"/>
