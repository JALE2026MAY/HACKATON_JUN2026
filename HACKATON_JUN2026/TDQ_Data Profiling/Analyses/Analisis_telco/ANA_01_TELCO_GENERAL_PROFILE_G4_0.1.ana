          <taggedValue xmi:id="_2jOCkmnXEfGJXK0qJt55Ng" tag="Description" value="counts the number of null rows"/>
          <sqlGenericExpression xmi:id="_2jOCk2nXEfGJXK0qJt55Ng" body="SELECT COUNT(*) FROM &lt;%=__TABLE_NAME__%> WHERE &lt;%=__COLUMN_NAMES__%> IS NULL &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
