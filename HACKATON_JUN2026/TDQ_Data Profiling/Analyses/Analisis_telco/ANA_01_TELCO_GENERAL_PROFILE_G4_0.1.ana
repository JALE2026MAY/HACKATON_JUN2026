      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_2RqYgGnXEfGJXK0qJt55Ng" count="7043" computed="true">
        <parameters xmi:id="_2RqYgWnXEfGJXK0qJt55Ng"/>
