      <indicators xsi:type="dataquality.indicators:MaxLengthIndicator" xmi:id="_2RqZAGnXEfGJXK0qJt55Ng" count="7043" computed="true" length="19">
        <parameters xmi:id="_2RqZAWnXEfGJXK0qJt55Ng">
          <textParameter xmi:id="_2RqZAmnXEfGJXK0qJt55Ng" useBlank="false"/>
        </parameters>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../../metadata/fileDelimited/Telcom_0.1.item#_cHMsPWnWEfGJXK0qJt55Ng"/>
        <indicatorDefinition href="../../../TDQ_Libraries/Indicators/System Indicators/Text Statistics/Maximal_Length_0.1.definition#_ccHq1RF2Ed2PKb6nEJEvhw"/>
        <builtInIndicatorDefinition xmi:id="_2q5X4GnXEfGJXK0qJt55Ng" name="Maximal Length" label="Maximal Length">
          <taggedValue xmi:id="_2q5X4WnXEfGJXK0qJt55Ng" tag="Description" value="computes the maximal length of a text field. Does not take into account the null and blank values when computing the maximal length."/>
          <taggedValue xmi:id="_2q5X4mnXEfGJXK0qJt55Ng" tag="Purpose" value="evaluates the length of the longest textual record of non-null and non-blank values"/>
          <sqlGenericExpression xmi:id="_2q5X42nXEfGJXK0qJt55Ng" body="SELECT MAX(CHAR_LENGTH(&lt;%=__COLUMN_NAMES__%>)) FROM &lt;%=__TABLE_NAME__%> WHERE (&lt;%=__COLUMN_NAMES__%> IS NOT NULL ) AND (TRIM(IFNULL(&lt;%=__COLUMN_NAMES__%>,'NULL TALEND')) &lt;> '' ) &lt;%=__AND_WHERE_CLAUSE__%>" language="SQL"/>
