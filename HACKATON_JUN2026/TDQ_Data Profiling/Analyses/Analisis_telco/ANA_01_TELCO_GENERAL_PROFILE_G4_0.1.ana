      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_2RqZWGnXEfGJXK0qJt55Ng" count="7043" computed="true">
        <parameters xmi:id="_2RqZWWnXEfGJXK0qJt55Ng"/>
