      <indicators xsi:type="dataquality.indicators:BlankCountIndicator" xmi:id="_2RqY4GnXEfGJXK0qJt55Ng" count="7043" computed="true">
        <parameters xmi:id="_2RqY4WnXEfGJXK0qJt55Ng"/>
