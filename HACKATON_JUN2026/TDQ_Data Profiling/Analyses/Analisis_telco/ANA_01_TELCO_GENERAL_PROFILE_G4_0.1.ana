      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_2RqZWmnXEfGJXK0qJt55Ng" count="7043" computed="true" distinctValueCount="3">
        <parameters xmi:id="_2RqZW2nXEfGJXK0qJt55Ng"/>
