      <indicators xsi:type="dataquality.indicators:SoundexFreqIndicator" xmi:id="_2RqZUWnXEfGJXK0qJt55Ng" count="7043" computed="true" distinctValueCount="3" uniqueValueCount="0" valueToFreq="" valueToDistinctFreq="">
