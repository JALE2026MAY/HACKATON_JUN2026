      <indicators xsi:type="dataquality.indicators:SoundexFreqIndicator" xmi:id="_2RqY2WnXEfGJXK0qJt55Ng" count="7043" computed="true" distinctValueCount="3" uniqueValueCount="0" valueToFreq="" valueToDistinctFreq="">
