      <indicators xsi:type="dataquality.indicators:DistinctCountIndicator" xmi:id="_2RqY4mnXEfGJXK0qJt55Ng" count="7043" computed="true" distinctValueCount="3">
        <parameters xmi:id="_2RqY42nXEfGJXK0qJt55Ng"/>
        <analyzedElement xsi:type="TalendMetadata:MetadataColumn" href="../../../metadata/fileDelimited/Telcom_0.1.item#_cHMsPGnWEfGJXK0qJt55Ng"/>
