        <builtInIndicatorDefinition xmi:id="_2pfpsGnXEfGJXK0qJt55Ng" name="Distinct Count" label="Distinct Count">
          <taggedValue xmi:id="_2pfpsWnXEfGJXK0qJt55Ng" tag="Description" value="counts the number of distinct rows (like a &quot;SELECT DISTINCT&quot; SQL statement)"/>
          <taggedValue xmi:id="_2pfpsmnXEfGJXK0qJt55Ng" tag="Purpose" value="evaluates the number of distinct records"/>
          <sqlGenericExpression xmi:id="_2pfps2nXEfGJXK0qJt55Ng" body="SELECT COUNT(*) FROM (SELECT DISTINCT &lt;%=__COLUMN_NAMES__%> FROM &lt;%=__TABLE_NAME__%> &lt;%=__WHERE_CLAUSE__%>) A" language="SQL"/>
