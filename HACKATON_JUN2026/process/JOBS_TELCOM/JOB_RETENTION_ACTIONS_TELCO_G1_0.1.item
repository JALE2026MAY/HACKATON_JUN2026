    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO mart_retention_kpi_summary_telco_grupo_uno ( &quot; +&#xD;&#xA;&quot;    action_run_id, gold_run_id_used, &quot; +&#xD;&#xA;&quot;    total_segments, target_segments, &quot; +&#xD;&#xA;&quot;    total_customers, target_customers, &quot; +&#xD;&#xA;&quot;    total_churn_customers, target_churn_customers, &quot; +&#xD;&#xA;&quot;    expected_saved_customers, expected_churn_reduction_pct, expected_monthly_revenue_protected &quot; +&#xD;&#xA;&quot;) &quot; +&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;    @action_run_id, &quot; +&#xD;&#xA;&quot;    @gold_run_id_used, &quot; +&#xD;&#xA;&quot;    COUNT(*) AS total_segments, &quot; +&#xD;&#xA;&quot;    SUM(CASE WHEN action_priority IN ('P1','P2') THEN 1 ELSE 0 END) AS target_segments, &quot; +&#xD;&#xA;&quot;    SUM(total_customers) AS total_customers, &quot; +&#xD;&#xA;&quot;    SUM(CASE WHEN action_priority IN ('P1','P2') THEN total_customers ELSE 0 END) AS target_customers, &quot; +&#xD;&#xA;&quot;    SUM(churn_customers) AS total_churn_customers, &quot; +&#xD;&#xA;&quot;    SUM(CASE WHEN action_priority IN ('P1','P2') THEN churn_customers ELSE 0 END) AS target_churn_customers, &quot; +&#xD;&#xA;&quot;    ROUND(SUM(CASE WHEN action_priority IN ('P1','P2') THEN expected_saved_customers ELSE 0 END), 2) AS expected_saved_customers, &quot; +&#xD;&#xA;&quot;    ROUND(100.0 * SUM(CASE WHEN action_priority IN ('P1','P2') THEN expected_saved_customers ELSE 0 END) / NULLIF(SUM(churn_customers), 0), 4) AS expected_churn_reduction_pct, &quot; +&#xD;&#xA;&quot;    ROUND(SUM(CASE WHEN action_priority IN ('P1','P2') THEN expected_monthly_revenue_protected ELSE 0 END), 2) AS expected_monthly_revenue_protected &quot; +&#xD;&#xA;&quot;FROM mart_retention_actions_telco_grupo_uno &quot; +&#xD;&#xA;&quot;WHERE action_run_id = @action_run_id&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
