    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO mart_retention_actions_telco_grupo_uno ( &quot; +&#xD;&#xA;&quot;    action_run_id, segment_key, &quot; +&#xD;&#xA;&quot;    contract_type, internet_service, payment_method, tenure_segment, service_level, monthly_charge_band, &quot; +&#xD;&#xA;&quot;    risk_level, total_customers, churn_customers, active_customers, churn_rate_pct, &quot; +&#xD;&#xA;&quot;    avg_monthly_charges, churn_monthly_revenue_risk, retention_priority_score, &quot; +&#xD;&#xA;&quot;    action_type, recommended_action, action_description, retention_uplift_pct, uplift_assumption, &quot; +&#xD;&#xA;&quot;    expected_saved_customers, expected_churn_reduction_pct, expected_monthly_revenue_protected, &quot; +&#xD;&#xA;&quot;    action_priority, business_rationale, gold_run_id_used &quot; +&#xD;&#xA;&quot;) &quot; +&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;    @action_run_id, &quot; +&#xD;&#xA;&quot;    y.segment_key, &quot; +&#xD;&#xA;&quot;    y.contract_type, &quot; +&#xD;&#xA;&quot;    y.internet_service, &quot; +&#xD;&#xA;&quot;    y.payment_method, &quot; +&#xD;&#xA;&quot;    y.tenure_segment, &quot; +&#xD;&#xA;&quot;    y.service_level, &quot; +&#xD;&#xA;&quot;    y.monthly_charge_band, &quot; +&#xD;&#xA;&quot;    y.risk_level, &quot; +&#xD;&#xA;&quot;    y.total_customers, &quot; +&#xD;&#xA;&quot;    y.churn_customers, &quot; +&#xD;&#xA;&quot;    y.active_customers, &quot; +&#xD;&#xA;&quot;    y.churn_rate_pct, &quot; +&#xD;&#xA;&quot;    y.avg_monthly_charges, &quot; +&#xD;&#xA;&quot;    y.churn_monthly_revenue_risk, &quot; +&#xD;&#xA;&quot;    y.retention_priority_score, &quot; +&#xD;&#xA;&quot;    y.action_type, &quot; +&#xD;&#xA;&quot;    y.recommended_action, &quot; +&#xD;&#xA;&quot;    y.action_description, &quot; +&#xD;&#xA;&quot;    y.retention_uplift_pct, &quot; +&#xD;&#xA;&quot;    y.uplift_assumption, &quot; +&#xD;&#xA;&quot;    ROUND(y.churn_customers * y.retention_uplift_pct / 100.0, 2) AS expected_saved_customers, &quot; +&#xD;&#xA;&quot;    ROUND(100.0 * (y.churn_customers * y.retention_uplift_pct / 100.0) / NULLIF(@total_churn_global, 0), 4) AS expected_churn_reduction_pct, &quot; +&#xD;&#xA;&quot;    ROUND((y.churn_customers * y.retention_uplift_pct / 100.0) * y.avg_monthly_charges, 2) AS expected_monthly_revenue_protected, &quot; +&#xD;&#xA;&quot;    y.action_priority, &quot; +&#xD;&#xA;&quot;    y.business_rationale, &quot; +&#xD;&#xA;&quot;    @gold_run_id_used &quot; +&#xD;&#xA;&quot;FROM ( &quot; +&#xD;&#xA;&quot;    SELECT &quot; +&#xD;&#xA;&quot;        s.segment_key, &quot; +&#xD;&#xA;&quot;        s.contract_type, &quot; +&#xD;&#xA;&quot;        s.internet_service, &quot; +&#xD;&#xA;&quot;        s.payment_method, &quot; +&#xD;&#xA;&quot;        s.tenure_segment, &quot; +&#xD;&#xA;&quot;        s.service_level, &quot; +&#xD;&#xA;&quot;        s.monthly_charge_band, &quot; +&#xD;&#xA;&quot;        s.risk_level, &quot; +&#xD;&#xA;&quot;        s.total_customers, &quot; +&#xD;&#xA;&quot;        s.churn_customers, &quot; +&#xD;&#xA;&quot;        s.active_customers, &quot; +&#xD;&#xA;&quot;        s.churn_rate_pct, &quot; +&#xD;&#xA;&quot;        s.avg_monthly_charges, &quot; +&#xD;&#xA;&quot;        s.churn_monthly_revenue_risk, &quot; +&#xD;&#xA;&quot;        s.retention_priority_score, &quot; +&#xD;&#xA; &#xD;&#xA;&quot;        CASE &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.contract_type = 'Month-to-month' THEN 'Migracion de contrato' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.payment_method = 'Electronic check' THEN 'Migracion de metodo de pago' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.tenure_segment IN ('Nuevo','Crecimiento') THEN 'Onboarding proactivo' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.internet_service = 'Fiber optic' THEN 'Soporte experiencia fibra' &quot; +&#xD;&#xA;&quot;            WHEN s.service_level = 'Basico' THEN 'Mejora de paquete de servicios' &quot; +&#xD;&#xA;&quot;            ELSE 'Monitoreo y fidelizacion' &quot; +&#xD;&#xA;&quot;        END AS action_type, &quot; +&#xD;&#xA; &#xD;&#xA;&quot;        CASE &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.contract_type = 'Month-to-month' THEN 'Ofrecer incentivo para migrar a contrato anual' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.payment_method = 'Electronic check' THEN 'Incentivar cambio a pago automatico con beneficio' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.tenure_segment IN ('Nuevo','Crecimiento') THEN 'Activar programa de onboarding y seguimiento temprano' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.internet_service = 'Fiber optic' THEN 'Ejecutar contacto proactivo de soporte y experiencia de servicio' &quot; +&#xD;&#xA;&quot;            WHEN s.service_level = 'Basico' THEN 'Ofrecer paquete de servicios complementarios con descuento' &quot; +&#xD;&#xA;&quot;            ELSE 'Mantener monitoreo y campanas de fidelizacion de bajo costo' &quot; +&#xD;&#xA;&quot;        END AS recommended_action, &quot; +&#xD;&#xA; &#xD;&#xA;&quot;        CASE &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.contract_type = 'Month-to-month' THEN 'Los clientes month-to-month presentan mayor flexibilidad para abandonar. La accion busca aumentar permanencia mediante incentivo de contrato anual.' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.payment_method = 'Electronic check' THEN 'El pago con electronic check se asocia a segmentos con mayor churn. La accion busca reducir friccion migrando a pago automatico.' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.tenure_segment IN ('Nuevo','Crecimiento') THEN 'Clientes nuevos o en crecimiento requieren acompanamiento temprano para reducir abandono inicial.' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level IN ('Alto','Medio alto') AND s.internet_service = 'Fiber optic' THEN 'Segmentos con fibra optica y churn alto requieren gestion de experiencia, soporte y percepcion de valor.' &quot; +&#xD;&#xA;&quot;            WHEN s.service_level = 'Basico' THEN 'Clientes con menor nivel de servicios pueden recibir una oferta empaquetada para aumentar valor percibido.' &quot; +&#xD;&#xA;&quot;            ELSE 'Segmento sin senales criticas; se recomienda monitoreo y fidelizacion general.' &quot; +&#xD;&#xA;&quot;        END AS action_description, &quot; +&#xD;&#xA; &#xD;&#xA;&quot;        CASE &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Alto' AND s.contract_type = 'Month-to-month' THEN 15.00 &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Alto' AND s.payment_method = 'Electronic check' THEN 12.00 &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Alto' AND s.tenure_segment IN ('Nuevo','Crecimiento') THEN 10.00 &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Alto' AND s.internet_service = 'Fiber optic' THEN 9.00 &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio alto' AND s.contract_type = 'Month-to-month' THEN 10.00 &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio alto' AND s.payment_method = 'Electronic check' THEN 8.00 &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio' THEN 5.00 &quot; +&#xD;&#xA;&quot;            ELSE 2.00 &quot; +&#xD;&#xA;&quot;        END AS retention_uplift_pct, &quot; +&#xD;&#xA; &#xD;&#xA;&quot;        CASE &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Alto' THEN 'Uplift supuesto alto por accion focalizada sobre segmento de alto riesgo. No representa causalidad real, es una estimacion de negocio para priorizacion.' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio alto' THEN 'Uplift supuesto moderado por intervencion sobre segmento relevante.' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio' THEN 'Uplift conservador para segmento con riesgo cercano o superior al promedio.' &quot; +&#xD;&#xA;&quot;            ELSE 'Uplift minimo para acciones de monitoreo y fidelizacion general.' &quot; +&#xD;&#xA;&quot;        END AS uplift_assumption, &quot; +&#xD;&#xA; &#xD;&#xA;&quot;        CASE &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Alto' AND s.total_customers >= 20 THEN 'P1' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio alto' AND s.total_customers >= 20 THEN 'P2' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio' THEN 'P3' &quot; +&#xD;&#xA;&quot;            ELSE 'P4' &quot; +&#xD;&#xA;&quot;        END AS action_priority, &quot; +&#xD;&#xA; &#xD;&#xA;&quot;        CASE &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Alto' AND s.total_customers >= 20 THEN 'Prioridad maxima por alto churn y volumen suficiente para intervencion comercial.' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio alto' AND s.total_customers >= 20 THEN 'Prioridad alta por churn superior al promedio y tamano relevante.' &quot; +&#xD;&#xA;&quot;            WHEN s.risk_level = 'Medio' THEN 'Prioridad media; requiere seguimiento y acciones selectivas.' &quot; +&#xD;&#xA;&quot;            ELSE 'Prioridad baja; mantener monitoreo.' &quot; +&#xD;&#xA;&quot;        END AS business_rationale &quot; +&#xD;&#xA; &#xD;&#xA;&quot;    FROM mart_retention_segments_telco_grupo_uno s &quot; +&#xD;&#xA;&quot;) y&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
