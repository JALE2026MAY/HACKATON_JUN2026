    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO dq_rule_results_telco_grupo_uno ( &quot; +&#xD;&#xA;&quot;    dq_run_id, rule_id, rule_name, dq_dimension, dataset_name, column_name, &quot; +&#xD;&#xA;&quot;    dimension_weight_pct, rule_weight_pct, target_operator, target_score_pct, &quot; +&#xD;&#xA;&quot;    evaluated_rows, passed_rows, failed_rows, actual_score_pct, failed_pct, &quot; +&#xD;&#xA;&quot;    threshold_result, severity, notes &quot; +&#xD;&#xA;&quot;) &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;@dq_run_id AS dq_run_id, &quot; +&#xD;&#xA;&quot;'DQ-COMP-001' AS rule_id, &quot; +&#xD;&#xA;&quot;'customer_id completo' AS rule_name, &quot; +&#xD;&#xA;&quot;'Completitud' AS dq_dimension, &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno' AS dataset_name, &quot; +&#xD;&#xA;&quot;'customer_id' AS column_name, &quot; +&#xD;&#xA;&quot;25.00 AS dimension_weight_pct, &quot; +&#xD;&#xA;&quot;25.00 AS rule_weight_pct, &quot; +&#xD;&#xA;&quot;'>=' AS target_operator, &quot; +&#xD;&#xA;&quot;100.0000 AS target_score_pct, &quot; +&#xD;&#xA;&quot;COUNT(*) AS evaluated_rows, &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN customer_id IS NOT NULL AND TRIM(customer_id) &lt;> '' THEN 1 ELSE 0 END) AS passed_rows, &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN customer_id IS NULL OR TRIM(customer_id) = '' THEN 1 ELSE 0 END) AS failed_rows, &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN customer_id IS NOT NULL AND TRIM(customer_id) &lt;> '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) AS actual_score_pct, &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN customer_id IS NULL OR TRIM(customer_id) = '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) AS failed_pct, &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN customer_id IS NOT NULL AND TRIM(customer_id) &lt;> '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END AS threshold_result, &quot; +&#xD;&#xA;&quot;'Alta' AS severity, &quot; +&#xD;&#xA;&quot;'Regla de bloqueo: customer_id debe estar completo.' AS notes &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-COMP-002', 'churn_label completo', 'Completitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'churn_label', 25.00, 20.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN churn_label IS NOT NULL AND TRIM(churn_label) &lt;> '' THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN churn_label IS NULL OR TRIM(churn_label) = '' THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN churn_label IS NOT NULL AND TRIM(churn_label) &lt;> '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN churn_label IS NULL OR TRIM(churn_label) = '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN churn_label IS NOT NULL AND TRIM(churn_label) &lt;> '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Alta', 'Variable objetivo textual completa.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-COMP-003', 'total_charges final completo', 'Completitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'total_charges', 25.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN total_charges IS NOT NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN total_charges IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN total_charges IS NOT NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN total_charges IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN total_charges IS NOT NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Alta', 'TotalCharges final debe quedar completo despues de imputacion.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-COMP-004', 'segmentaciones completas', 'Completitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'service_level, tenure_segment, monthly_charge_band, segment_key', 25.00, 15.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN service_level IS NOT NULL AND TRIM(service_level) &lt;> '' AND tenure_segment IS NOT NULL AND TRIM(tenure_segment) &lt;> '' AND monthly_charge_band IS NOT NULL AND TRIM(monthly_charge_band) &lt;> '' AND segment_key IS NOT NULL AND TRIM(segment_key) &lt;> '' THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN service_level IS NULL OR TRIM(service_level) = '' OR tenure_segment IS NULL OR TRIM(tenure_segment) = '' OR monthly_charge_band IS NULL OR TRIM(monthly_charge_band) = '' OR segment_key IS NULL OR TRIM(segment_key) = '' THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN service_level IS NOT NULL AND TRIM(service_level) &lt;> '' AND tenure_segment IS NOT NULL AND TRIM(tenure_segment) &lt;> '' AND monthly_charge_band IS NOT NULL AND TRIM(monthly_charge_band) &lt;> '' AND segment_key IS NOT NULL AND TRIM(segment_key) &lt;> '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN service_level IS NULL OR TRIM(service_level) = '' OR tenure_segment IS NULL OR TRIM(tenure_segment) = '' OR monthly_charge_band IS NULL OR TRIM(monthly_charge_band) = '' OR segment_key IS NULL OR TRIM(segment_key) = '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN service_level IS NOT NULL AND TRIM(service_level) &lt;> '' AND tenure_segment IS NOT NULL AND TRIM(tenure_segment) &lt;> '' AND monthly_charge_band IS NOT NULL AND TRIM(monthly_charge_band) &lt;> '' AND segment_key IS NOT NULL AND TRIM(segment_key) &lt;> '' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Segmentaciones listas para GOLD y dashboard.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-COMP-005', 'total_charges_raw blancos controlados', 'Completitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'total_charges_raw', 25.00, 15.00, '>=', 99.8000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN (total_charges_raw IS NOT NULL AND TRIM(total_charges_raw) &lt;> '') OR ((total_charges_raw IS NULL OR TRIM(total_charges_raw) = '') AND total_charges_was_imputed = 1 AND tenure_months = 0) THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN NOT ((total_charges_raw IS NOT NULL AND TRIM(total_charges_raw) &lt;> '') OR ((total_charges_raw IS NULL OR TRIM(total_charges_raw) = '') AND total_charges_was_imputed = 1 AND tenure_months = 0)) THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN (total_charges_raw IS NOT NULL AND TRIM(total_charges_raw) &lt;> '') OR ((total_charges_raw IS NULL OR TRIM(total_charges_raw) = '') AND total_charges_was_imputed = 1 AND tenure_months = 0) THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN NOT ((total_charges_raw IS NOT NULL AND TRIM(total_charges_raw) &lt;> '') OR ((total_charges_raw IS NULL OR TRIM(total_charges_raw) = '') AND total_charges_was_imputed = 1 AND tenure_months = 0)) THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN (total_charges_raw IS NOT NULL AND TRIM(total_charges_raw) &lt;> '') OR ((total_charges_raw IS NULL OR TRIM(total_charges_raw) = '') AND total_charges_was_imputed = 1 AND tenure_months = 0) THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 99.8000 THEN 'CONTROLADO' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Los blancos originales de TotalCharges se aceptan solo si estan imputados y justificados.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-VAL-001', 'churn_flag dominio 0/1', 'Validez', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'churn_flag', 25.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN churn_flag IN (0,1) THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN churn_flag NOT IN (0,1) OR churn_flag IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN churn_flag IN (0,1) THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN churn_flag NOT IN (0,1) OR churn_flag IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN churn_flag IN (0,1) THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Alta', 'Variable objetivo binaria valida.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-VAL-002', 'contract_type dominio permitido', 'Validez', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'contract_type', 25.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN contract_type IN ('Month-to-month','One year','Two year') THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN contract_type NOT IN ('Month-to-month','One year','Two year') OR contract_type IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN contract_type IN ('Month-to-month','One year','Two year') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN contract_type NOT IN ('Month-to-month','One year','Two year') OR contract_type IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN contract_type IN ('Month-to-month','One year','Two year') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Dominio contractual cerrado.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-VAL-003', 'payment_method dominio permitido', 'Validez', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'payment_method', 25.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN payment_method IN ('Electronic check','Mailed check','Bank transfer (automatic)','Credit card (automatic)') THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN payment_method NOT IN ('Electronic check','Mailed check','Bank transfer (automatic)','Credit card (automatic)') OR payment_method IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN payment_method IN ('Electronic check','Mailed check','Bank transfer (automatic)','Credit card (automatic)') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN payment_method NOT IN ('Electronic check','Mailed check','Bank transfer (automatic)','Credit card (automatic)') OR payment_method IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN payment_method IN ('Electronic check','Mailed check','Bank transfer (automatic)','Credit card (automatic)') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Dominio de metodos de pago controlado.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-VAL-004', 'internet_service dominio permitido', 'Validez', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'internet_service', 25.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN internet_service IN ('DSL','Fiber optic','No') THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN internet_service NOT IN ('DSL','Fiber optic','No') OR internet_service IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN internet_service IN ('DSL','Fiber optic','No') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN internet_service NOT IN ('DSL','Fiber optic','No') OR internet_service IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN internet_service IN ('DSL','Fiber optic','No') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Dominio de servicio de internet controlado.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-UNI-001', 'customer_id unico', 'Unicidad', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'customer_id', 20.00, 100.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;COUNT(DISTINCT customer_id), &quot; +&#xD;&#xA;&quot;COUNT(*) - COUNT(DISTINCT customer_id), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * COUNT(DISTINCT customer_id) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * (COUNT(*) - COUNT(DISTINCT customer_id)) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * COUNT(DISTINCT customer_id) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Alta', 'Regla de bloqueo: un registro por cliente.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-CON-001', 'phone_service consistente con multiple_lines', 'Consistencia', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'phone_service, multiple_lines', 20.00, 30.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN phone_service &lt;> 'No' OR (phone_service = 'No' AND multiple_lines = 'No phone service') THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN phone_service = 'No' AND multiple_lines &lt;> 'No phone service' THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN phone_service &lt;> 'No' OR (phone_service = 'No' AND multiple_lines = 'No phone service') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN phone_service = 'No' AND multiple_lines &lt;> 'No phone service' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN phone_service &lt;> 'No' OR (phone_service = 'No' AND multiple_lines = 'No phone service') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Alta', 'Regla cruzada de servicios telefonicos.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-CON-002', 'internet_service consistente con servicios online', 'Consistencia', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'internet_service y servicios digitales', 20.00, 40.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN internet_service &lt;> 'No' OR (internet_service = 'No' AND online_security = 'No internet service' AND online_backup = 'No internet service' AND device_protection = 'No internet service' AND tech_support = 'No internet service' AND streaming_tv = 'No internet service' AND streaming_movies = 'No internet service') THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN internet_service = 'No' AND (online_security &lt;> 'No internet service' OR online_backup &lt;> 'No internet service' OR device_protection &lt;> 'No internet service' OR tech_support &lt;> 'No internet service' OR streaming_tv &lt;> 'No internet service' OR streaming_movies &lt;> 'No internet service') THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN internet_service &lt;> 'No' OR (internet_service = 'No' AND online_security = 'No internet service' AND online_backup = 'No internet service' AND device_protection = 'No internet service' AND tech_support = 'No internet service' AND streaming_tv = 'No internet service' AND streaming_movies = 'No internet service') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN internet_service = 'No' AND (online_security &lt;> 'No internet service' OR online_backup &lt;> 'No internet service' OR device_protection &lt;> 'No internet service' OR tech_support &lt;> 'No internet service' OR streaming_tv &lt;> 'No internet service' OR streaming_movies &lt;> 'No internet service') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN internet_service &lt;> 'No' OR (internet_service = 'No' AND online_security = 'No internet service' AND online_backup = 'No internet service' AND device_protection = 'No internet service' AND tech_support = 'No internet service' AND streaming_tv = 'No internet service' AND streaming_movies = 'No internet service') THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Alta', 'Regla cruzada de internet y servicios digitales.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-CON-003', 'imputacion de total_charges consistente con tenure', 'Consistencia', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'total_charges_was_imputed, tenure_months', 20.00, 30.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN total_charges_was_imputed = 0 OR (total_charges_was_imputed = 1 AND tenure_months = 0) THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN total_charges_was_imputed = 1 AND tenure_months &lt;> 0 THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN total_charges_was_imputed = 0 OR (total_charges_was_imputed = 1 AND tenure_months = 0) THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN total_charges_was_imputed = 1 AND tenure_months &lt;> 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN total_charges_was_imputed = 0 OR (total_charges_was_imputed = 1 AND tenure_months = 0) THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Toda imputacion de TotalCharges debe corresponder a clientes nuevos.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-PRE-001', 'tenure_months en rango plausible', 'Precision / Exactitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'tenure_months', 10.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN tenure_months BETWEEN 0 AND 72 THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN tenure_months &lt; 0 OR tenure_months > 72 OR tenure_months IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN tenure_months BETWEEN 0 AND 72 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN tenure_months &lt; 0 OR tenure_months > 72 OR tenure_months IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN tenure_months BETWEEN 0 AND 72 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Antiguedad del cliente debe estar entre 0 y 72 meses.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-PRE-002', 'monthly_charges positivo', 'Precision / Exactitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'monthly_charges', 10.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN monthly_charges > 0 THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN monthly_charges &lt;= 0 OR monthly_charges IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN monthly_charges > 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN monthly_charges &lt;= 0 OR monthly_charges IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN monthly_charges > 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Cargo mensual debe ser positivo.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-PRE-003', 'total_charges no negativo', 'Precision / Exactitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'total_charges', 10.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN total_charges >= 0 THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN total_charges &lt; 0 OR total_charges IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN total_charges >= 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN total_charges &lt; 0 OR total_charges IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN total_charges >= 0 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'Cargo total no debe ser negativo.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT @dq_run_id, 'DQ-PRE-004', 'service_score en rango plausible', 'Precision / Exactitud', &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno', 'service_score', 10.00, 25.00, '>=', 100.0000, &quot; +&#xD;&#xA;&quot;COUNT(*), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN service_score BETWEEN 0 AND 6 THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;SUM(CASE WHEN service_score &lt; 0 OR service_score > 6 OR service_score IS NULL THEN 1 ELSE 0 END), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN service_score BETWEEN 0 AND 6 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;ROUND(100.0 * SUM(CASE WHEN service_score &lt; 0 OR service_score > 6 OR service_score IS NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4), &quot; +&#xD;&#xA;&quot;CASE WHEN ROUND(100.0 * SUM(CASE WHEN service_score BETWEEN 0 AND 6 THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 4) >= 100.0000 THEN 'PASS' ELSE 'FAIL' END, &quot; +&#xD;&#xA;&quot;'Media', 'service_score debe estar entre 0 y 6.' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno&quot;"/>
