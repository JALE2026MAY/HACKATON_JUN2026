  <node componentName="tMysqlRow" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="840" posY="400">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBRow_9" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DB_VERSION" value="MYSQL_8" show="false"/>
