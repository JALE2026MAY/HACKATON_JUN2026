    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:L4cOgqM+NxzPYFkwHi1zVjHQ5+9EYyrVMITpdkF0" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO dq_rule_violations_telco_grupo_uno ( &quot; +&#xD;&#xA;&quot;    violation_id, dq_run_id, rule_id, dq_dimension, dataset_name, customer_id, &quot; +&#xD;&#xA;&quot;    column_name, reject_reason, observed_value, expected_value, severity &quot; +&#xD;&#xA;&quot;) &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;CONCAT(@dq_run_id, '_DQ-COMP-001_', COALESCE(customer_id, 'NULL'), '_', COALESCE(CAST(source_row_number AS CHAR), 'NO_ROW')) AS violation_id, &quot; +&#xD;&#xA;&quot;@dq_run_id AS dq_run_id, &quot; +&#xD;&#xA;&quot;'DQ-COMP-001' AS rule_id, &quot; +&#xD;&#xA;&quot;'Completitud' AS dq_dimension, &quot; +&#xD;&#xA;&quot;'stg_telco_customer_churn_grupo_uno' AS dataset_name, &quot; +&#xD;&#xA;&quot;customer_id AS customer_id, &quot; +&#xD;&#xA;&quot;'customer_id' AS column_name, &quot; +&#xD;&#xA;&quot;'customer_id nulo o blanco' AS reject_reason, &quot; +&#xD;&#xA;&quot;COALESCE(customer_id, 'NULL') AS observed_value, &quot; +&#xD;&#xA;&quot;'customer_id no nulo ni blanco' AS expected_value, &quot; +&#xD;&#xA;&quot;'Alta' AS severity &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&quot;WHERE customer_id IS NULL OR TRIM(customer_id) = '' &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;CONCAT(@dq_run_id, '_DQ-VAL-001_', COALESCE(customer_id, 'NULL')), &quot; +&#xD;&#xA;&quot;@dq_run_id, 'DQ-VAL-001', 'Validez', 'stg_telco_customer_churn_grupo_uno', customer_id, &quot; +&#xD;&#xA;&quot;'churn_flag', 'churn_flag fuera del dominio 0/1', COALESCE(CAST(churn_flag AS CHAR), 'NULL'), '0 o 1', 'Alta' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&quot;WHERE churn_flag NOT IN (0,1) OR churn_flag IS NULL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;CONCAT(@dq_run_id, '_DQ-COMP-003_', COALESCE(customer_id, 'NULL')), &quot; +&#xD;&#xA;&quot;@dq_run_id, 'DQ-COMP-003', 'Completitud', 'stg_telco_customer_churn_grupo_uno', customer_id, &quot; +&#xD;&#xA;&quot;'total_charges', 'total_charges nulo despues de STG', 'NULL', 'total_charges no nulo', 'Alta' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&quot;WHERE total_charges IS NULL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;CONCAT(@dq_run_id, '_DQ-CON-001_', COALESCE(customer_id, 'NULL')), &quot; +&#xD;&#xA;&quot;@dq_run_id, 'DQ-CON-001', 'Consistencia', 'stg_telco_customer_churn_grupo_uno', customer_id, &quot; +&#xD;&#xA;&quot;'phone_service, multiple_lines', 'phone_service = No pero multiple_lines no es No phone service', &quot; +&#xD;&#xA;&quot;CONCAT('phone_service=', COALESCE(phone_service, 'NULL'), '; multiple_lines=', COALESCE(multiple_lines, 'NULL')), &quot; +&#xD;&#xA;&quot;'multiple_lines = No phone service', 'Alta' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&quot;WHERE phone_service = 'No' AND multiple_lines &lt;> 'No phone service' &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;CONCAT(@dq_run_id, '_DQ-CON-002_', COALESCE(customer_id, 'NULL')), &quot; +&#xD;&#xA;&quot;@dq_run_id, 'DQ-CON-002', 'Consistencia', 'stg_telco_customer_churn_grupo_uno', customer_id, &quot; +&#xD;&#xA;&quot;'internet_service, servicios_online', 'internet_service = No pero algun servicio online no es No internet service', &quot; +&#xD;&#xA;&quot;CONCAT('internet_service=', COALESCE(internet_service, 'NULL'), '; online_security=', COALESCE(online_security, 'NULL'), '; online_backup=', COALESCE(online_backup, 'NULL'), '; device_protection=', COALESCE(device_protection, 'NULL'), '; tech_support=', COALESCE(tech_support, 'NULL'), '; streaming_tv=', COALESCE(streaming_tv, 'NULL'), '; streaming_movies=', COALESCE(streaming_movies, 'NULL')), &quot; +&#xD;&#xA;&quot;'Todos los servicios online = No internet service', 'Alta' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&quot;WHERE internet_service = 'No' &quot; +&#xD;&#xA;&quot;AND (online_security &lt;> 'No internet service' OR online_backup &lt;> 'No internet service' OR device_protection &lt;> 'No internet service' OR tech_support &lt;> 'No internet service' OR streaming_tv &lt;> 'No internet service' OR streaming_movies &lt;> 'No internet service') &quot; +&#xD;&#xA;&#xD;&#xA;&quot;UNION ALL &quot; +&#xD;&#xA;&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;CONCAT(@dq_run_id, '_DQ-CON-003_', COALESCE(customer_id, 'NULL')), &quot; +&#xD;&#xA;&quot;@dq_run_id, 'DQ-CON-003', 'Consistencia', 'stg_telco_customer_churn_grupo_uno', customer_id, &quot; +&#xD;&#xA;&quot;'total_charges_was_imputed, tenure_months', 'total_charges imputado pero tenure_months no es 0', &quot; +&#xD;&#xA;&quot;CONCAT('total_charges_was_imputed=', COALESCE(CAST(total_charges_was_imputed AS CHAR), 'NULL'), '; tenure_months=', COALESCE(CAST(tenure_months AS CHAR), 'NULL')), &quot; +&#xD;&#xA;&quot;'Si total_charges_was_imputed = 1 entonces tenure_months = 0', 'Media' &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno &quot; +&#xD;&#xA;&quot;WHERE total_charges_was_imputed = 1 AND tenure_months &lt;> 0&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="PROPAGATE_RECORD_SET" value="false"/>
    <elementParameter field="COLUMN_LIST" name="RECORD_SET_COLUMN" value="" show="false"/>
    <elementParameter field="CHECK" name="USE_PREPAREDSTATEMENT" value="false"/>
    <elementParameter field="TABLE" name="SET_PREPAREDSTATEMENT_PARAMETERS" show="false"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
    <elementParameter field="TECHNICAL" name="ENCODING:ENCODING_TYPE" value="ISO-8859-15"/>
    <elementParameter field="TEXT" name="COMMIT_EVERY" value="10000" show="false"/>
