    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO dq_score_global_telco_grupo_uno ( &quot; +&#xD;&#xA;&quot;    dq_run_id, dataset_name, global_dq_score, score_status, total_rules, &quot; +&#xD;&#xA;&quot;    passed_rules, failed_rules, controlled_rules, blocking_failures, certification_status &quot; +&#xD;&#xA;&quot;) &quot; +&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;    s.dq_run_id, &quot; +&#xD;&#xA;&quot;    'stg_telco_customer_churn_grupo_uno', &quot; +&#xD;&#xA;&quot;    ROUND(SUM(s.weighted_score), 4), &quot; +&#xD;&#xA;&quot;    CASE &quot; +&#xD;&#xA;&quot;        WHEN ROUND(SUM(s.weighted_score), 4) >= 95 THEN 'Excelente' &quot; +&#xD;&#xA;&quot;        WHEN ROUND(SUM(s.weighted_score), 4) >= 90 THEN 'Bueno' &quot; +&#xD;&#xA;&quot;        WHEN ROUND(SUM(s.weighted_score), 4) >= 80 THEN 'Aceptable con observaciones' &quot; +&#xD;&#xA;&quot;        WHEN ROUND(SUM(s.weighted_score), 4) >= 70 THEN 'Riesgo medio' &quot; +&#xD;&#xA;&quot;        ELSE 'Riesgo alto' &quot; +&#xD;&#xA;&quot;    END, &quot; +&#xD;&#xA;&quot;    SUM(s.total_rules), &quot; +&#xD;&#xA;&quot;    SUM(s.passed_rules), &quot; +&#xD;&#xA;&quot;    SUM(s.failed_rules), &quot; +&#xD;&#xA;&quot;    SUM(s.controlled_rules), &quot; +&#xD;&#xA;&quot;    ( &quot; +&#xD;&#xA;&quot;        SELECT COUNT(*) &quot; +&#xD;&#xA;&quot;        FROM dq_rule_results_telco_grupo_uno r &quot; +&#xD;&#xA;&quot;        WHERE r.dq_run_id = s.dq_run_id &quot; +&#xD;&#xA;&quot;          AND r.threshold_result = 'FAIL' &quot; +&#xD;&#xA;&quot;          AND r.rule_id IN ('DQ-COMP-001','DQ-COMP-002','DQ-COMP-003','DQ-VAL-001','DQ-UNI-001','DQ-CON-001','DQ-CON-002') &quot; +&#xD;&#xA;&quot;    ), &quot; +&#xD;&#xA;&quot;    CASE &quot; +&#xD;&#xA;&quot;        WHEN ROUND(SUM(s.weighted_score), 4) >= 95 &quot; +&#xD;&#xA;&quot;         AND ( &quot; +&#xD;&#xA;&quot;            SELECT COUNT(*) &quot; +&#xD;&#xA;&quot;            FROM dq_rule_results_telco_grupo_uno r &quot; +&#xD;&#xA;&quot;            WHERE r.dq_run_id = s.dq_run_id &quot; +&#xD;&#xA;&quot;              AND r.threshold_result = 'FAIL' &quot; +&#xD;&#xA;&quot;              AND r.rule_id IN ('DQ-COMP-001','DQ-COMP-002','DQ-COMP-003','DQ-VAL-001','DQ-UNI-001','DQ-CON-001','DQ-CON-002') &quot; +&#xD;&#xA;&quot;         ) = 0 &quot; +&#xD;&#xA;&quot;        THEN 'CERTIFICADO' &quot; +&#xD;&#xA;&quot;        ELSE 'NO CERTIFICADO' &quot; +&#xD;&#xA;&quot;    END &quot; +&#xD;&#xA;&quot;FROM dq_score_dimension_telco_grupo_uno s &quot; +&#xD;&#xA;&quot;WHERE s.dq_run_id = @dq_run_id &quot; +&#xD;&#xA;&quot;GROUP BY s.dq_run_id&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="PROPAGATE_RECORD_SET" value="false"/>
