    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String endTs = TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, TalendDate.getCurrentDate());&#xD;&#xA;&#xD;&#xA;Long startMillis = (Long) globalMap.get(&quot;MASTER_START_MILLIS&quot;);&#xD;&#xA;long endMillis = System.currentTimeMillis();&#xD;&#xA;&#xD;&#xA;long durationSeconds = 0;&#xD;&#xA;if (startMillis != null) {&#xD;&#xA;    durationSeconds = (endMillis - startMillis) / 1000;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;long minutes = durationSeconds / 60;&#xD;&#xA;long seconds = durationSeconds % 60;&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;&quot;);&#xD;&#xA;System.out.println(&quot;==============================================================&quot;);&#xD;&#xA;System.out.println(&quot; PIPELINE MAESTRO FINALIZADO CORRECTAMENTE&quot;);&#xD;&#xA;System.out.println(&quot;==============================================================&quot;);&#xD;&#xA;System.out.println(&quot;Producto de datos : Telco Retention Intelligence&quot;);&#xD;&#xA;System.out.println(&quot;MASTER_RUN_ID     : &quot; + context.MASTER_RUN_ID);&#xD;&#xA;System.out.println(&quot;Fecha inicio      : &quot; + context.MASTER_START_TS);&#xD;&#xA;System.out.println(&quot;Fecha fin         : &quot; + endTs);&#xD;&#xA;System.out.println(&quot;Duración total    : &quot; + minutes + &quot; min &quot; + seconds + &quot; seg&quot;);&#xD;&#xA;System.out.println(&quot;--------------------------------------------------------------&quot;);&#xD;&#xA;System.out.println(&quot;Etapas ejecutadas correctamente:&quot;);&#xD;&#xA;System.out.println(&quot;  OK  1. Ingesta IBM Telco hacia SingleStore&quot;);&#xD;&#xA;System.out.println(&quot;  OK  2. Construcción de capa STG&quot;);&#xD;&#xA;System.out.println(&quot;  OK  3. Ejecución de reglas de calidad DQ&quot;);&#xD;&#xA;System.out.println(&quot;  OK  4. Construcción de modelo GOLD&quot;);&#xD;&#xA;System.out.println(&quot;  OK  5. Generación de acciones de retención&quot;);&#xD;&#xA;System.out.println(&quot;  OK  6. Publicación analítica en Snowflake&quot;);&#xD;&#xA;System.out.println(&quot;--------------------------------------------------------------&quot;);&#xD;&#xA;System.out.println(&quot;Resultado         : PIPELINE END-TO-END EJECUTADO CON ÉXITO&quot;);&#xD;&#xA;System.out.println(&quot;Consumo final     : Snowflake + Tableau Cloud&quot;);&#xD;&#xA;System.out.println(&quot;Mensaje negocio   : Producto listo para análisis ejecutivo de churn y retención&quot;);&#xD;&#xA;System.out.println(&quot;==============================================================&quot;);&#xD;&#xA;System.out.println(&quot;&quot;);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
