  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="800" posY="80">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String ts = TalendDate.formatDate(&quot;yyyyMMdd_HHmmss&quot;, TalendDate.getCurrentDate());&#xD;&#xA;String readableTs = TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, TalendDate.getCurrentDate());&#xD;&#xA;&#xD;&#xA;context.MASTER_RUN_ID = &quot;RUN_MASTER_TELCO_&quot; + ts;&#xD;&#xA;context.MASTER_START_TS = readableTs;&#xD;&#xA;&#xD;&#xA;globalMap.put(&quot;MASTER_START_MILLIS&quot;, System.currentTimeMillis());&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;&quot;);&#xD;&#xA;System.out.println(&quot;==============================================================&quot;);&#xD;&#xA;System.out.println(&quot; INICIANDO PIPELINE MAESTRO - TELCO RETENTION INTELLIGENCE&quot;);&#xD;&#xA;System.out.println(&quot;==============================================================&quot;);&#xD;&#xA;System.out.println(&quot;Producto de datos : Telco Retention Intelligence&quot;);&#xD;&#xA;System.out.println(&quot;Industria         : Telecomunicaciones&quot;);&#xD;&#xA;System.out.println(&quot;Objetivo          : Segmentación de churn y recomendación de acciones de retención&quot;);&#xD;&#xA;System.out.println(&quot;MASTER_RUN_ID     : &quot; + context.MASTER_RUN_ID);&#xD;&#xA;System.out.println(&quot;Fecha inicio      : &quot; + context.MASTER_START_TS);&#xD;&#xA;System.out.println(&quot;--------------------------------------------------------------&quot;);&#xD;&#xA;System.out.println(&quot;Etapas a ejecutar:&quot;);&#xD;&#xA;System.out.println(&quot;  1. Ingesta IBM Telco hacia SingleStore&quot;);&#xD;&#xA;System.out.println(&quot;  2. Construcción de capa STG&quot;);&#xD;&#xA;System.out.println(&quot;  3. Ejecución de reglas de calidad DQ&quot;);&#xD;&#xA;System.out.println(&quot;  4. Construcción de modelo GOLD&quot;);&#xD;&#xA;System.out.println(&quot;  5. Generación de acciones de retención&quot;);&#xD;&#xA;System.out.println(&quot;  6. Publicación analítica en Snowflake&quot;);&#xD;&#xA;System.out.println(&quot;--------------------------------------------------------------&quot;);&#xD;&#xA;System.out.println(&quot;Estado inicial    : PIPELINE INICIADO&quot;);&#xD;&#xA;System.out.println(&quot;==============================================================&quot;);&#xD;&#xA;System.out.println(&quot;&quot;);"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="tJava_INIT_MASTER_RUN"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
