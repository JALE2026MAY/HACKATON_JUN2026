  <node componentName="tMysqlRow" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="400" posY="200">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBRow_3" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DB_VERSION" value="MYSQL_8" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1"/>
    <elementParameter field="TEXT" name="HOST" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="PORT" value="&quot;3306&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="MySQL" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:SuFVaLubeh3ufGhSLesc98vDLgawdNDdAItic8M+" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO stg_telco_customer_churn_grupo_uno (&quot;&#xD;&#xA;+ &quot;customer_id, gender, senior_citizen, partner_flag, dependents_flag, &quot;&#xD;&#xA;+ &quot;tenure_months, phone_service, multiple_lines, internet_service, &quot;&#xD;&#xA;+ &quot;online_security, online_backup, device_protection, tech_support, streaming_tv, streaming_movies, &quot;&#xD;&#xA;+ &quot;contract_type, paperless_billing_flag, payment_method, &quot;&#xD;&#xA;+ &quot;monthly_charges, total_charges, total_charges_raw, total_charges_was_imputed, &quot;&#xD;&#xA;+ &quot;churn_flag, churn_label, &quot;&#xD;&#xA;+ &quot;service_score, service_level, tenure_segment, monthly_charge_band, segment_key, &quot;&#xD;&#xA;+ &quot;stg_quality_status, stg_notes, &quot;&#xD;&#xA;+ &quot;source_run_id, stg_run_id, source_file, source_row_number, processed_at&quot;&#xD;&#xA;+ &quot;) &quot;&#xD;&#xA;+ &quot;SELECT &quot;&#xD;&#xA;+ &quot;b.customer_id, &quot;&#xD;&#xA;+ &quot;b.gender, &quot;&#xD;&#xA;+ &quot;b.senior_citizen, &quot;&#xD;&#xA;+ &quot;b.partner_flag, &quot;&#xD;&#xA;+ &quot;b.dependents_flag, &quot;&#xD;&#xA;+ &quot;b.tenure_months, &quot;&#xD;&#xA;+ &quot;b.phone_service, &quot;&#xD;&#xA;+ &quot;b.multiple_lines, &quot;&#xD;&#xA;+ &quot;b.internet_service, &quot;&#xD;&#xA;+ &quot;b.online_security, &quot;&#xD;&#xA;+ &quot;b.online_backup, &quot;&#xD;&#xA;+ &quot;b.device_protection, &quot;&#xD;&#xA;+ &quot;b.tech_support, &quot;&#xD;&#xA;+ &quot;b.streaming_tv, &quot;&#xD;&#xA;+ &quot;b.streaming_movies, &quot;&#xD;&#xA;+ &quot;b.contract_type, &quot;&#xD;&#xA;+ &quot;b.paperless_billing_flag, &quot;&#xD;&#xA;+ &quot;b.payment_method, &quot;&#xD;&#xA;+ &quot;b.monthly_charges, &quot;&#xD;&#xA;+ &quot;CASE &quot;&#xD;&#xA;+ &quot;    WHEN (b.total_charges_raw IS NULL OR TRIM(b.total_charges_raw) = '') AND b.tenure_months = 0 THEN 0.00 &quot;&#xD;&#xA;+ &quot;    WHEN b.total_charges_raw IS NULL OR TRIM(b.total_charges_raw) = '' THEN NULL &quot;&#xD;&#xA;+ &quot;    ELSE CAST(TRIM(b.total_charges_raw) AS DECIMAL(12,2)) &quot;&#xD;&#xA;+ &quot;END AS total_charges, &quot;&#xD;&#xA;+ &quot;b.total_charges_raw, &quot;&#xD;&#xA;+ &quot;CASE &quot;&#xD;&#xA;+ &quot;    WHEN (b.total_charges_raw IS NULL OR TRIM(b.total_charges_raw) = '') AND b.tenure_months = 0 THEN 1 &quot;&#xD;&#xA;+ &quot;    ELSE 0 &quot;&#xD;&#xA;+ &quot;END AS total_charges_was_imputed, &quot;&#xD;&#xA;+ &quot;b.churn_flag, &quot;&#xD;&#xA;+ &quot;b.churn_label, &quot;&#xD;&#xA;+ &quot;b.service_score, &quot;&#xD;&#xA;+ &quot;CASE &quot;&#xD;&#xA;+ &quot;    WHEN b.service_score BETWEEN 0 AND 1 THEN 'Basico' &quot;&#xD;&#xA;+ &quot;    WHEN b.service_score BETWEEN 2 AND 3 THEN 'Intermedio' &quot;&#xD;&#xA;+ &quot;    WHEN b.service_score BETWEEN 4 AND 6 THEN 'Premium' &quot;&#xD;&#xA;+ &quot;    ELSE 'Sin clasificar' &quot;&#xD;&#xA;+ &quot;END AS service_level, &quot;&#xD;&#xA;+ &quot;CASE &quot;&#xD;&#xA;+ &quot;    WHEN b.tenure_months BETWEEN 0 AND 6 THEN 'Nuevo' &quot;&#xD;&#xA;+ &quot;    WHEN b.tenure_months BETWEEN 7 AND 24 THEN 'Crecimiento' &quot;&#xD;&#xA;+ &quot;    WHEN b.tenure_months BETWEEN 25 AND 48 THEN 'Estable' &quot;&#xD;&#xA;+ &quot;    WHEN b.tenure_months BETWEEN 49 AND 72 THEN 'Leal' &quot;&#xD;&#xA;+ &quot;    ELSE 'Sin clasificar' &quot;&#xD;&#xA;+ &quot;END AS tenure_segment, &quot;&#xD;&#xA;+ &quot;CASE &quot;&#xD;&#xA;+ &quot;    WHEN b.monthly_charges &lt;= 35 THEN 'Bajo' &quot;&#xD;&#xA;+ &quot;    WHEN b.monthly_charges > 35 AND b.monthly_charges &lt;= 70 THEN 'Medio' &quot;&#xD;&#xA;+ &quot;    WHEN b.monthly_charges > 70 THEN 'Alto' &quot;&#xD;&#xA;+ &quot;    ELSE 'Sin clasificar' &quot;&#xD;&#xA;+ &quot;END AS monthly_charge_band, &quot;&#xD;&#xA;+ &quot;CONCAT(&quot;&#xD;&#xA;+ &quot;    COALESCE(b.contract_type, 'Sin contrato'), '|', &quot;&#xD;&#xA;+ &quot;    COALESCE(b.internet_service, 'Sin internet'), '|', &quot;&#xD;&#xA;+ &quot;    CASE &quot;&#xD;&#xA;+ &quot;        WHEN b.service_score BETWEEN 0 AND 1 THEN 'Basico' &quot;&#xD;&#xA;+ &quot;        WHEN b.service_score BETWEEN 2 AND 3 THEN 'Intermedio' &quot;&#xD;&#xA;+ &quot;        WHEN b.service_score BETWEEN 4 AND 6 THEN 'Premium' &quot;&#xD;&#xA;+ &quot;        ELSE 'Sin clasificar' &quot;&#xD;&#xA;+ &quot;    END&quot;&#xD;&#xA;+ &quot;) AS segment_key, &quot;&#xD;&#xA;+ &quot;CASE &quot;&#xD;&#xA;+ &quot;    WHEN b.customer_id IS NULL OR b.customer_id = '' THEN 'REVIEW' &quot;&#xD;&#xA;+ &quot;    WHEN b.tenure_months IS NULL THEN 'REVIEW' &quot;&#xD;&#xA;+ &quot;    WHEN b.monthly_charges IS NULL THEN 'REVIEW' &quot;&#xD;&#xA;+ &quot;    WHEN b.churn_flag IS NULL THEN 'REVIEW' &quot;&#xD;&#xA;+ &quot;    WHEN b.total_charges_raw IS NULL OR TRIM(b.total_charges_raw) = '' THEN &quot;&#xD;&#xA;+ &quot;        CASE WHEN b.tenure_months = 0 THEN 'OK' ELSE 'REVIEW' END &quot;&#xD;&#xA;+ &quot;    ELSE 'OK' &quot;&#xD;&#xA;+ &quot;END AS stg_quality_status, &quot;&#xD;&#xA;+ &quot;CASE &quot;&#xD;&#xA;+ &quot;    WHEN (b.total_charges_raw IS NULL OR TRIM(b.total_charges_raw) = '') AND b.tenure_months = 0 THEN 'TotalCharges imputado a 0 por tenure=0' &quot;&#xD;&#xA;+ &quot;    WHEN b.total_charges_raw IS NULL OR TRIM(b.total_charges_raw) = '' THEN 'TotalCharges faltante no imputado' &quot;&#xD;&#xA;+ &quot;    ELSE '' &quot;&#xD;&#xA;+ &quot;END AS stg_notes, &quot;&#xD;&#xA;+ &quot;b.source_run_id, &quot;&#xD;&#xA;+ &quot;'&quot; + context.run_id + &quot;' AS stg_run_id, &quot;&#xD;&#xA;+ &quot;b.source_file, &quot;&#xD;&#xA;+ &quot;b.source_row_number, &quot;&#xD;&#xA;+ &quot;NOW(6) AS processed_at &quot;&#xD;&#xA;+ &quot;FROM ( &quot;&#xD;&#xA;+ &quot;    SELECT &quot;&#xD;&#xA;+ &quot;    TRIM(r.`customerID`) AS customer_id, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`gender`) AS gender, &quot;&#xD;&#xA;+ &quot;    CAST(TRIM(r.`SeniorCitizen`) AS SIGNED) AS senior_citizen, &quot;&#xD;&#xA;+ &quot;    CASE WHEN LOWER(TRIM(r.`Partner`)) = 'yes' THEN 1 WHEN LOWER(TRIM(r.`Partner`)) = 'no' THEN 0 ELSE NULL END AS partner_flag, &quot;&#xD;&#xA;+ &quot;    CASE WHEN LOWER(TRIM(r.`Dependents`)) = 'yes' THEN 1 WHEN LOWER(TRIM(r.`Dependents`)) = 'no' THEN 0 ELSE NULL END AS dependents_flag, &quot;&#xD;&#xA;+ &quot;    CAST(TRIM(r.`tenure`) AS SIGNED) AS tenure_months, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`PhoneService`) AS phone_service, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`MultipleLines`) AS multiple_lines, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`InternetService`) AS internet_service, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`OnlineSecurity`) AS online_security, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`OnlineBackup`) AS online_backup, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`DeviceProtection`) AS device_protection, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`TechSupport`) AS tech_support, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`StreamingTV`) AS streaming_tv, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`StreamingMovies`) AS streaming_movies, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`Contract`) AS contract_type, &quot;&#xD;&#xA;+ &quot;    CASE WHEN LOWER(TRIM(r.`PaperlessBilling`)) = 'yes' THEN 1 WHEN LOWER(TRIM(r.`PaperlessBilling`)) = 'no' THEN 0 ELSE NULL END AS paperless_billing_flag, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`PaymentMethod`) AS payment_method, &quot;&#xD;&#xA;+ &quot;    CAST(TRIM(r.`MonthlyCharges`) AS DECIMAL(10,2)) AS monthly_charges, &quot;&#xD;&#xA;+ &quot;    r.`TotalCharges` AS total_charges_raw, &quot;&#xD;&#xA;+ &quot;    CASE WHEN LOWER(TRIM(r.`Churn`)) = 'yes' THEN 1 WHEN LOWER(TRIM(r.`Churn`)) = 'no' THEN 0 ELSE NULL END AS churn_flag, &quot;&#xD;&#xA;+ &quot;    TRIM(r.`Churn`) AS churn_label, &quot;&#xD;&#xA;+ &quot;    ( &quot;&#xD;&#xA;+ &quot;        CASE WHEN LOWER(TRIM(r.`OnlineSecurity`)) = 'yes' THEN 1 ELSE 0 END + &quot;&#xD;&#xA;+ &quot;        CASE WHEN LOWER(TRIM(r.`OnlineBackup`)) = 'yes' THEN 1 ELSE 0 END + &quot;&#xD;&#xA;+ &quot;        CASE WHEN LOWER(TRIM(r.`DeviceProtection`)) = 'yes' THEN 1 ELSE 0 END + &quot;&#xD;&#xA;+ &quot;        CASE WHEN LOWER(TRIM(r.`TechSupport`)) = 'yes' THEN 1 ELSE 0 END + &quot;&#xD;&#xA;+ &quot;        CASE WHEN LOWER(TRIM(r.`StreamingTV`)) = 'yes' THEN 1 ELSE 0 END + &quot;&#xD;&#xA;+ &quot;        CASE WHEN LOWER(TRIM(r.`StreamingMovies`)) = 'yes' THEN 1 ELSE 0 END &quot;&#xD;&#xA;+ &quot;    ) AS service_score, &quot;&#xD;&#xA;+ &quot;    r.`_load_run` AS source_run_id, &quot;&#xD;&#xA;+ &quot;    r.`_source_file` AS source_file, &quot;&#xD;&#xA;+ &quot;    r.`_source_row_number` AS source_row_number &quot;&#xD;&#xA;+ &quot;    FROM raw_telco_customer_churn_grupo_uno r &quot;&#xD;&#xA;+ &quot;    WHERE r.`_load_run` = ( &quot;&#xD;&#xA;+ &quot;        SELECT run_id &quot;&#xD;&#xA;+ &quot;        FROM pipeline_run_audit_grupo_uno &quot;&#xD;&#xA;+ &quot;        WHERE target_table = 'raw_telco_customer_churn_grupo_uno' &quot;&#xD;&#xA;+ &quot;          AND layer_name = 'RAW' &quot;&#xD;&#xA;+ &quot;          AND status = 'FINISHED' &quot;&#xD;&#xA;+ &quot;        ORDER BY finished_at DESC &quot;&#xD;&#xA;+ &quot;        LIMIT 1 &quot;&#xD;&#xA;+ &quot;    ) &quot;&#xD;&#xA;+ &quot;) b&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
