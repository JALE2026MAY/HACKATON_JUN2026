    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO gold_fact_contracts_telco_grupo_uno ( &quot; +&#xD;&#xA;&quot;    customer_id, phone_service, multiple_lines, internet_service, &quot; +&#xD;&#xA;&quot;    online_security, online_backup, device_protection, tech_support, &quot; +&#xD;&#xA;&quot;    streaming_tv, streaming_movies, contract_type, paperless_billing_flag, &quot; +&#xD;&#xA;&quot;    payment_method, monthly_charges, total_charges, total_charges_was_imputed, &quot; +&#xD;&#xA;&quot;    churn_flag, churn_label, service_score, &quot; +&#xD;&#xA;&quot;    source_run_id, stg_run_id, dq_run_id_used, gold_run_id &quot; +&#xD;&#xA;&quot;) &quot; +&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;    customer_id, &quot; +&#xD;&#xA;&quot;    phone_service, &quot; +&#xD;&#xA;&quot;    multiple_lines, &quot; +&#xD;&#xA;&quot;    internet_service, &quot; +&#xD;&#xA;&quot;    online_security, &quot; +&#xD;&#xA;&quot;    online_backup, &quot; +&#xD;&#xA;&quot;    device_protection, &quot; +&#xD;&#xA;&quot;    tech_support, &quot; +&#xD;&#xA;&quot;    streaming_tv, &quot; +&#xD;&#xA;&quot;    streaming_movies, &quot; +&#xD;&#xA;&quot;    contract_type, &quot; +&#xD;&#xA;&quot;    paperless_billing_flag, &quot; +&#xD;&#xA;&quot;    payment_method, &quot; +&#xD;&#xA;&quot;    monthly_charges, &quot; +&#xD;&#xA;&quot;    total_charges, &quot; +&#xD;&#xA;&quot;    total_charges_was_imputed, &quot; +&#xD;&#xA;&quot;    churn_flag, &quot; +&#xD;&#xA;&quot;    churn_label, &quot; +&#xD;&#xA;&quot;    service_score, &quot; +&#xD;&#xA;&quot;    source_run_id, &quot; +&#xD;&#xA;&quot;    stg_run_id, &quot; +&#xD;&#xA;&quot;    @dq_run_id_used, &quot; +&#xD;&#xA;&quot;    @gold_run_id &quot; +&#xD;&#xA;&quot;FROM stg_telco_customer_churn_grupo_uno&quot;"/>
