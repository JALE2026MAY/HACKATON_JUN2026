    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT &quot; +&#xD;&#xA;&quot;    @gold_run_id AS gold_run_id, &quot; +&#xD;&#xA;&quot;    @dq_run_id_used AS dq_run_id_used, &quot; +&#xD;&#xA;&quot;    (SELECT COUNT(*) FROM gold_dim_customer_telco_grupo_uno) AS dim_customer_rows, &quot; +&#xD;&#xA;&quot;    (SELECT COUNT(*) FROM gold_fact_contracts_telco_grupo_uno) AS fact_contracts_rows, &quot; +&#xD;&#xA;&quot;    (SELECT COUNT(*) FROM mart_retention_segments_telco_grupo_uno) AS mart_segments_rows, &quot; +&#xD;&#xA;&quot;    (SELECT COUNT(*) FROM mart_retention_segments_telco_grupo_uno WHERE risk_level IN ('Alto', 'Medio alto')) AS high_priority_segments &quot;"/>
