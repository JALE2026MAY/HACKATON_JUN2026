  <node componentName="tMysqlRow" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="800" posY="560">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tDBRow_8" show="false"/>
    <elementParameter field="CLOSED_LIST" name="DB_VERSION" value="MYSQL_8" show="false"/>
    <elementParameter field="CHECK" name="USE_EXISTING_CONNECTION" value="true"/>
    <elementParameter field="COMPONENT_LIST" name="CONNECTION" value="tDBConnection_1"/>
    <elementParameter field="TEXT" name="HOST" value="context.db_host" show="false"/>
    <elementParameter field="TEXT" name="PORT" value="&quot;3306&quot;" show="false"/>
    <elementParameter field="TEXT" name="DBNAME" value="context.db_name" show="false"/>
    <elementParameter field="TEXT" name="TYPE" value="MySQL" show="false"/>
    <elementParameter field="TEXT" name="USER" value="&quot;&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="PASS" value="enc:system.encryption.key.v1:zy80RtgZaOtBHBMbDaf1PJ1dqNDxzhNRV4wyUjio" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;INSERT INTO mart_retention_segments_telco_grupo_uno ( &quot; +&#xD;&#xA;&quot;    segment_key, contract_type, internet_service, payment_method, &quot; +&#xD;&#xA;&quot;    tenure_segment, service_level, monthly_charge_band, &quot; +&#xD;&#xA;&quot;    total_customers, churn_customers, active_customers, &quot; +&#xD;&#xA;&quot;    churn_rate_pct, active_rate_pct, &quot; +&#xD;&#xA;&quot;    avg_monthly_charges, avg_total_charges, total_monthly_revenue, churn_monthly_revenue_risk, &quot; +&#xD;&#xA;&quot;    risk_level, risk_reason, retention_priority_score, &quot; +&#xD;&#xA;&quot;    dq_run_id_used, gold_run_id &quot; +&#xD;&#xA;&quot;) &quot; +&#xD;&#xA;&quot;SELECT &quot; +&#xD;&#xA;&quot;    x.segment_key, &quot; +&#xD;&#xA;&quot;    x.contract_type, &quot; +&#xD;&#xA;&quot;    x.internet_service, &quot; +&#xD;&#xA;&quot;    x.payment_method, &quot; +&#xD;&#xA;&quot;    x.tenure_segment, &quot; +&#xD;&#xA;&quot;    x.service_level, &quot; +&#xD;&#xA;&quot;    x.monthly_charge_band, &quot; +&#xD;&#xA;&quot;    x.total_customers, &quot; +&#xD;&#xA;&quot;    x.churn_customers, &quot; +&#xD;&#xA;&quot;    x.active_customers, &quot; +&#xD;&#xA;&quot;    x.churn_rate_pct, &quot; +&#xD;&#xA;&quot;    x.active_rate_pct, &quot; +&#xD;&#xA;&quot;    x.avg_monthly_charges, &quot; +&#xD;&#xA;&quot;    x.avg_total_charges, &quot; +&#xD;&#xA;&quot;    x.total_monthly_revenue, &quot; +&#xD;&#xA;&quot;    x.churn_monthly_revenue_risk, &quot; +&#xD;&#xA;&quot;    CASE &quot; +&#xD;&#xA;&quot;        WHEN x.total_customers >= 20 AND x.churn_rate_pct >= 45 THEN 'Alto' &quot; +&#xD;&#xA;&quot;        WHEN x.total_customers >= 20 AND x.churn_rate_pct >= 30 THEN 'Medio alto' &quot; +&#xD;&#xA;&quot;        WHEN x.churn_rate_pct >= 26.50 THEN 'Medio' &quot; +&#xD;&#xA;&quot;        ELSE 'Bajo' &quot; +&#xD;&#xA;&quot;    END AS risk_level, &quot; +&#xD;&#xA;&quot;    CASE &quot; +&#xD;&#xA;&quot;        WHEN x.total_customers >= 20 AND x.churn_rate_pct >= 45 THEN 'Segmento con churn muy superior al promedio y tamaño suficiente para intervencion prioritaria.' &quot; +&#xD;&#xA;&quot;        WHEN x.total_customers >= 20 AND x.churn_rate_pct >= 30 THEN 'Segmento con churn superior al promedio y volumen relevante.' &quot; +&#xD;&#xA;&quot;        WHEN x.churn_rate_pct >= 26.50 THEN 'Segmento con churn cercano o superior al promedio global.' &quot; +&#xD;&#xA;&quot;        ELSE 'Segmento con churn bajo o controlado.' &quot; +&#xD;&#xA;&quot;    END AS risk_reason, &quot; +&#xD;&#xA;&quot;    ROUND(x.churn_rate_pct * LOG(x.total_customers + 1), 4) AS retention_priority_score, &quot; +&#xD;&#xA;&quot;    @dq_run_id_used, &quot; +&#xD;&#xA;&quot;    @gold_run_id &quot; +&#xD;&#xA;&quot;FROM ( &quot; +&#xD;&#xA;&quot;    SELECT &quot; +&#xD;&#xA;&quot;        CONCAT( &quot; +&#xD;&#xA;&quot;            COALESCE(f.contract_type, 'NA'), '|', &quot; +&#xD;&#xA;&quot;            COALESCE(f.internet_service, 'NA'), '|', &quot; +&#xD;&#xA;&quot;            COALESCE(f.payment_method, 'NA'), '|', &quot; +&#xD;&#xA;&quot;            COALESCE(d.tenure_segment, 'NA'), '|', &quot; +&#xD;&#xA;&quot;            COALESCE(d.service_level, 'NA'), '|', &quot; +&#xD;&#xA;&quot;            COALESCE(d.monthly_charge_band, 'NA') &quot; +&#xD;&#xA;&quot;        ) AS segment_key, &quot; +&#xD;&#xA;&quot;        f.contract_type, &quot; +&#xD;&#xA;&quot;        f.internet_service, &quot; +&#xD;&#xA;&quot;        f.payment_method, &quot; +&#xD;&#xA;&quot;        d.tenure_segment, &quot; +&#xD;&#xA;&quot;        d.service_level, &quot; +&#xD;&#xA;&quot;        d.monthly_charge_band, &quot; +&#xD;&#xA;&quot;        COUNT(*) AS total_customers, &quot; +&#xD;&#xA;&quot;        SUM(f.churn_flag) AS churn_customers, &quot; +&#xD;&#xA;&quot;        COUNT(*) - SUM(f.churn_flag) AS active_customers, &quot; +&#xD;&#xA;&quot;        ROUND(100.0 * SUM(f.churn_flag) / NULLIF(COUNT(*), 0), 4) AS churn_rate_pct, &quot; +&#xD;&#xA;&quot;        ROUND(100.0 * (COUNT(*) - SUM(f.churn_flag)) / NULLIF(COUNT(*), 0), 4) AS active_rate_pct, &quot; +&#xD;&#xA;&quot;        ROUND(AVG(f.monthly_charges), 2) AS avg_monthly_charges, &quot; +&#xD;&#xA;&quot;        ROUND(AVG(f.total_charges), 2) AS avg_total_charges, &quot; +&#xD;&#xA;&quot;        ROUND(SUM(f.monthly_charges), 2) AS total_monthly_revenue, &quot; +&#xD;&#xA;&quot;        ROUND(SUM(CASE WHEN f.churn_flag = 1 THEN f.monthly_charges ELSE 0 END), 2) AS churn_monthly_revenue_risk &quot; +&#xD;&#xA;&quot;    FROM gold_fact_contracts_telco_grupo_uno f &quot; +&#xD;&#xA;&quot;    INNER JOIN gold_dim_customer_telco_grupo_uno d &quot; +&#xD;&#xA;&quot;        ON f.customer_id = d.customer_id &quot; +&#xD;&#xA;&quot;    GROUP BY &quot; +&#xD;&#xA;&quot;        f.contract_type, &quot; +&#xD;&#xA;&quot;        f.internet_service, &quot; +&#xD;&#xA;&quot;        f.payment_method, &quot; +&#xD;&#xA;&quot;        d.tenure_segment, &quot; +&#xD;&#xA;&quot;        d.service_level, &quot; +&#xD;&#xA;&quot;        d.monthly_charge_band &quot; +&#xD;&#xA;&quot;) x&quot;"/>
    <elementParameter field="LABEL" name="NOTE" value="This option only applies when deploying and running in the Talend Runtime" show="false"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" value="false" show="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="false"/>
    <elementParameter field="TEXT" name="PROPERTIES" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="PROPAGATE_RECORD_SET" value="false"/>
    <elementParameter field="COLUMN_LIST" name="RECORD_SET_COLUMN" value="" show="false"/>
    <elementParameter field="CHECK" name="USE_PREPAREDSTATEMENT" value="false"/>
    <elementParameter field="TABLE" name="SET_PREPAREDSTATEMENT_PARAMETERS" show="false"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" value="&quot;ISO-8859-15&quot;" show="false"/>
    <elementParameter field="TECHNICAL" name="ENCODING:ENCODING_TYPE" value="ISO-8859-15"/>
    <elementParameter field="TEXT" name="COMMIT_EVERY" value="10000" show="false"/>
    <elementParameter field="TEXT" name="LABEL" value="tDBRow_insert_mart_segments"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tDBRow_8"/>
    <metadata connector="REJECT" name="REJECT">
